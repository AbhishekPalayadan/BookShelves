<%- include("../partials/admin/header", { title: "Sales Report" }) %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

.sales-container{
padding:30px;
background:#f4f6f9;
min-height:100vh;
}

.page-title{
font-size:28px;
font-weight:700;
margin-bottom:25px;
}

/* FILTER */

.filter-card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 4px 15px rgba(0,0,0,0.05);
margin-bottom:25px;
}

.filter-row{
display:flex;
gap:15px;
flex-wrap:wrap;
align-items:center;
}

.filter-row select,
.filter-row input{
padding:8px 12px;
border:1px solid #ddd;
border-radius:6px;
}

.apply-btn{
background:#ff4757;
color:white;
border:none;
padding:9px 18px;
border-radius:6px;
cursor:pointer;
}

/* SUMMARY */

.summary-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:30px;
}

.summary-card{
background:white;
padding:22px;
border-radius:12px;
box-shadow:0 4px 14px rgba(0,0,0,0.05);
display:flex;
justify-content:space-between;
align-items:center;
}

.summary-card h4{
font-size:13px;
color:#888;
margin-bottom:5px;
}

.summary-card h2{
font-size:24px;
font-weight:700;
}

/* TABLE */

.table-card{
background:white;
border-radius:12px;
box-shadow:0 4px 14px rgba(0,0,0,0.05);
overflow:hidden;
}

.sales-table{
width:100%;
border-collapse:collapse;
}

.sales-table th,
.sales-table td{
padding:14px;
text-align:center;
font-size:14px;
}

.sales-table th{
background:#f7f7f7;
font-weight:600;
}

.status{
padding:4px 10px;
border-radius:5px;
font-size:12px;
font-weight:600;
}

.delivered{
background:#e8f8f5;
color:#1abc9c;
}

.cancelled{
background:#fdecea;
color:#e74c3c;
}

</style>


<div class="sales-container">

<h1 class="page-title">Sales Report</h1>

<div class="filter-card">

<form method="GET" action="/admin/sales">

<div class="filter-row">

<select name="filter" id="filterSelect">

<option value="">Select Filter</option>

<option value="daily" <%= filter==="daily"?"selected":"" %>>
Today
</option>

<option value="weekly" <%= filter==="weekly"?"selected":"" %>>
Last 7 Days
</option>

<option value="monthly" <%= filter==="monthly"?"selected":"" %>>
Last 30 Days
</option>

<option value="custom" <%= filter==="custom"?"selected":"" %>>
Custom Range
</option>

</select>


<input type="date"
name="fromDate"
id="fromDate"
value="<%= fromDate || '' %>"
style="<%= filter==='custom' ? '' : 'display:none' %>"
>


<input type="date"
name="toDate"
id="toDate"
value="<%= toDate || '' %>"
style="<%= filter==='custom' ? '' : 'display:none' %>"
>


<button class="apply-btn">
Apply
</button>

</div>

</form>

</div>



<div class="summary-grid">

<div class="summary-card">
<div>
<h4>Total Products Sold</h4>
<h2><%= overallSalesCount %></h2>
</div>
</div>

<div class="summary-card">
<div>
<h4>Total Revenue</h4>
<h2 style="color:green;">₹ <%= overallOrderAmount %></h2>
</div>
</div>

<div class="summary-card">
<div>
<h4>Total Discount</h4>
<h2 style="color:#ff4757;">₹ <%= overallDiscount %></h2>
</div>
</div>

</div>


<div class="table-card">

<table class="sales-table">

<thead>

<tr>

<th>Order ID</th>
<th>Date</th>
<th>Product</th>
<th>Quantity</th>
<th>Price</th>
<th>Discount</th>
<th>Final</th>
<th>Payment</th>

</tr>

</thead>

<tbody>

<% if(orders.length > 0){ %>

<% orders.forEach(item => { %>

<tr>

<td><%= item.orderId %></td>

<td>
<%= new Date(item.createdAt).toLocaleDateString("en-IN") %>
</td>

<td><%= item.productName %></td>

<td><%= item.quantity %></td>

<td>₹ <%= item.price %></td>

<td style="color:#ff4757;">
₹ <%= item.discount || 0 %>
</td>

<td style="color:green;">
₹ <%= item.total %>
</td>

<td><%= item.paymentMethod %></td>


</tr>

<% }) %>

<% } else { %>

<tr>
<td colspan="9">No sales found</td>
</tr>

<% } %>

</tbody>

</table>

</div>

</div>


<script>

document.getElementById("filterSelect").addEventListener("change",function(){

const showCustom = this.value === "custom"

document.getElementById("fromDate").style.display =
showCustom ? "block" : "none"

document.getElementById("toDate").style.display =
showCustom ? "block" : "none"

})

</script>

<%- include("../partials/admin/footer") %>