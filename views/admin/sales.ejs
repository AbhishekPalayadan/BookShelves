<%- include("../partials/admin/header", { title: "Sales Report" }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
.sales-container {
  padding: 30px;
  background: #f4f6f9;
  min-height: 100vh;
}

.page-title {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 25px;
}

/* FILTER */
.filter-card {
  background: white;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  margin-bottom: 25px;
}

.filter-row {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  align-items: center;
}

.filter-row select,
.filter-row input {
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
}

.apply-btn {
  background: #ff4757;
  color: white;
  border: none;
  padding: 9px 18px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
}

.apply-btn:hover { background: #e0313f; }

/* SUMMARY */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
  margin-bottom: 25px;
}

.summary-card {
  background: white;
  padding: 22px;
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-card h4 {
  font-size: 13px;
  color: #888;
  margin-bottom: 6px;
}

.summary-card h2 {
  font-size: 24px;
  font-weight: 700;
}

.summary-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}

/* NOTE BOX */
.note-box {
  background: #fff8e1;
  border-left: 4px solid #f39c12;
  padding: 10px 16px;
  border-radius: 6px;
  font-size: 13px;
  color: #856404;
  margin-bottom: 20px;
}

/* TABLE */
.table-card {
  background: white;
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.05);
  overflow: hidden;
  margin-bottom: 20px;
}

.sales-table {
  width: 100%;
  border-collapse: collapse;
}

.sales-table th,
.sales-table td {
  padding: 14px;
  text-align: center;
  font-size: 14px;
  border-bottom: 1px solid #f0f0f0;
}

.sales-table th {
  background: #f7f7f7;
  font-weight: 600;
  color: #444;
}

.sales-table tr:hover { background: #fafafa; }

.badge {
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
}

.badge-cod      { background: #e8f4fd; color: #1a73e8; }
.badge-razorpay { background: #f0e8ff; color: #7c3aed; }
.badge-wallet   { background: #e8f8f0; color: #16a34a; }
.badge-success  { background: #e8f8f0; color: #16a34a; }
.badge-pending  { background: #fff8e1; color: #d97706; }

.download-row {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}

/* PAGINATION */
.pagination-wrap {
  padding: 16px 20px;
  display: flex;
  justify-content: center;
}

.empty-state {
  text-align: center;
  padding: 50px;
  color: #aaa;
  font-size: 15px;
}

.page-title i {
  margin-right: 8px;
  color: #1a73e8;
}

.note-box i {
  margin-right: 6px;
}

.apply-btn i {
  margin-right: 6px;
}
</style>

<div class="sales-container">

  <h1 class="page-title">
    <i class="fas fa-chart-line"></i> Sales Report
  </h1>

  <!-- FILTER -->
  <div class="filter-card">
    <form method="GET" action="/admin/sales">
      <div class="filter-row">

        <select name="filter" id="filterSelect">
          <option value="">All Time</option>
          <option value="daily"   <%= filter === "daily"   ? "selected" : "" %>>Today</option>
          <option value="weekly"  <%= filter === "weekly"  ? "selected" : "" %>>Last 7 Days</option>
          <option value="monthly" <%= filter === "monthly" ? "selected" : "" %>>Last 30 Days</option>
          <option value="custom"  <%= filter === "custom"  ? "selected" : "" %>>Custom Range</option>
        </select>

        <input
          type="date"
          name="fromDate"
          id="fromDate"
          value="<%= fromDate || '' %>"
          style="<%= filter === 'custom' ? '' : 'display:none' %>"
        >

        <input
          type="date"
          name="toDate"
          id="toDate"
          value="<%= toDate || '' %>"
          style="<%= filter === 'custom' ? '' : 'display:none' %>"
        >

        <button type="submit" class="apply-btn">Apply Filter</button>

      </div>
    </form>
  </div>

  <!-- NOTE -->
  <div class="note-box">
    <i class="fas fa-circle-info"></i>
    This report only includes <strong>confirmed, active sales</strong>.
    Fully cancelled orders and returned items are excluded.
    COD orders with pending payment are included as valid sales.
  </div>

  <!-- SUMMARY CARDS -->
  <div class="summary-grid">

    <div class="summary-card">
      <div>
        <h4>Total Items Sold</h4>
        <h2><%= overallSalesCount %></h2>
      </div>
      <div class="summary-icon" style="background:#e8f4fd; color:#1a73e8;">
        <i class="fas fa-cart-shopping"></i>
      </div>
    </div>

    <div class="summary-card">
      <div>
        <h4>Total Revenue</h4>
        <h2 style="color:#16a34a;">₹ <%= overallOrderAmount %></h2>
      </div>
      <div class="summary-icon" style="background:#e8f8f0; color:#16a34a;">
        <i class="fas fa-indian-rupee-sign"></i>
      </div>
      
    </div>

    <div class="summary-card">
      <div>
        <h4>Total Offer Discount Given</h4>
        <h2 style="color:#ff4757;">₹ <%= overallDiscount %></h2>
      </div>
      <div class="summary-icon" style="background:#fff0f0; color:#ff4757;">
        <i class="fas fa-tags"></i>
      </div>
    </div>

  </div>

  <!-- DOWNLOAD BUTTONS -->
  <div class="download-row">
    <a href="/admin/sales/pdf?<%= queryString %>" class="apply-btn">
      <i class="fas fa-file-pdf"></i> Download PDF
    </a>
    
    <a href="/admin/sales/excel?<%= queryString %>" class="apply-btn">
      <i class="fas fa-file-excel"></i> Download Excel
    </a>
  </div>

  <!-- TABLE -->
  <div class="table-card">
    <table class="sales-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Order ID</th>
          <th>Date</th>
          <th>Product</th>
          <th>Qty</th>
          <th>Unit Price</th>
          <th>Offer Discount</th>
          <th>Item Total</th>
          <th>Payment</th>
          <th>Pay Status</th>
        </tr>
      </thead>
      <tbody>

        <% if (orders.length > 0) { %>
          <% orders.forEach((item, index) => { %>
            <tr>
              <td><%= ((currentPage - 1) * limit) + index + 1 %></td>
              <td><strong><%= item.orderId %></strong></td>
              <td><%= new Date(item.createdAt).toLocaleDateString("en-IN") %></td>
              <td style="text-align:left;"><%= item.productName || "-" %></td>
              <td><%= item.quantity %></td>
              <td>₹ <%= item.price %></td>
              <td style="color:#ff4757;">
                ₹ <%= Number(item.offerDiscount || 0).toFixed(2) %>
              </td>
              <td style="color:#16a34a; font-weight:600;">
                ₹ <%= Number(item.itemTotal || 0).toFixed(2) %>
              </td>
              <td>
                <% if (item.paymentMethod === "COD") { %>
                  <span class="badge badge-cod">COD</span>
                <% } else if (item.paymentMethod === "RAZORPAY") { %>
                  <span class="badge badge-razorpay">Razorpay</span>
                <% } else { %>
                  <span class="badge badge-wallet">Wallet</span>
                <% } %>
              </td>
              <td>
                <% if (item.paymentStatus === "Success") { %>
                  <span class="badge badge-success">Paid</span>
                <% } else { %>
                  <span class="badge badge-pending">Pending</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="10" class="empty-state">
              No sales found for the selected period.
            </td>
          </tr>
        <% } %>

      </tbody>
    </table>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
    <div class="pagination-wrap">
      <nav>
        <ul class="pagination">

          <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
            <a class="page-link"
              href="?page=1&limit=<%= limit %>&<%= queryString %>">
              First
            </a>
          </li>

          <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link"
                href="?page=<%= i %>&limit=<%= limit %>&<%= queryString %>">
                <%= i %>
              </a>
            </li>
          <% } %>

          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
            <a class="page-link"
              href="?page=<%= totalPages %>&limit=<%= limit %>&<%= queryString %>">
              Last
            </a>
          </li>

        </ul>
      </nav>
    </div>
    <% } %>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const filterSelect = document.getElementById("filterSelect");
  const fromDate     = document.getElementById("fromDate");
  const toDate       = document.getElementById("toDate");

  filterSelect.addEventListener("change", function () {
    const isCustom = this.value === "custom";
    fromDate.style.display = isCustom ? "block" : "none";
    toDate.style.display   = isCustom ? "block" : "none";
  });

  // Validate custom date range before submit
  filterSelect.closest("form").addEventListener("submit", function (e) {
    if (filterSelect.value === "custom") {
      if (!fromDate.value || !toDate.value) {
        e.preventDefault();
        Swal.fire("Missing Dates", "Please select both From and To dates.", "warning");
        return;
      }
      if (fromDate.value > toDate.value) {
        e.preventDefault();
        Swal.fire("Invalid Range", "From date must be before To date.", "error");
        return;
      }
    }
  });
</script>

<%- include("../partials/admin/footer") %>