<%- include("../partials/admin/header", { 
    title: "Coupons",
    adminName: typeof adminName !== "undefined" ? adminName : "Admin",
    activeMenu: "coupons"
  }) %>
  
  <style>
  .dashboard-content {
    background-color: #f5f5f5;
    min-height: 100vh;
    padding: 20px;
  }
  
  .content-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  
  .content-header h1 {
    font-size: 28px;
    font-weight: 600;
    color: #333;
  }
  
  .add-btn {
    padding: 8px 14px;
    background: #28a745;
    border: none;
    color: #fff;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
  }
  
  .table-order {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 4px rgba(0,0,0,.05);
  }
  
  .table-order table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .table-order th,
  .table-order td {
    padding: 16px;
    font-size: 14px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }
  
  .status-badge {
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }
  
  .status-active {
    background:#d4edda;
    color:#155724;
  }
  
  .status-disabled {
    background:#f8d7da;
    color:#721c24;
  }
  
  .action-btn {
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    margin-right: 6px;
  }
  
  .edit-btn { background:#007bff; color:#fff; }
  .toggle-btn { background:#ffc107; color:#000; }
  .delete-btn { background:#dc3545; color:#fff; }

  .modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-box {
  background: #fff;
  width: 100%;
  max-width: 450px;
  padding: 30px;
  border-radius: 12px;
}

.info-input {
  width: 100%;
  padding: 10px;
  margin-bottom: 2px;
  border-radius: 6px;
  border: 1px solid #ddd;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}

.btn-cancel {
  padding: 8px 16px;
  border: none;
  background: #ccc;
  border-radius: 4px;
}

.edit-profile-btn {
  padding: 8px 16px;
  border: none;
  background: #28a745;
  color: white;
  border-radius: 4px;
}
.error-msg {
  color: red;
  font-size: 12px;
  margin-bottom:11px;
}
.status-expired {
  background: #fff3cd;
  color: #856404;
}
  </style>
  
  <div class="dashboard-content">
    <div class="content-header">
      <h1>Coupon Management</h1>
      <button class="add-btn" onclick="openCouponModal()">
        + Add Coupon
      </button>
    </div>
  
    <div class="table-order">
      <table>
        <thead>
          <tr>
            <th>Code</th>
            <th>Discount</th>
            <th>Max Discount (₹)</th>
            <th>Min Cart (₹)</th>
            <th>Usage Limit</th>
            <th>Expiry</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>

          <% if(!coupons || coupons.length === 0){ %>
            <tr>
              <td colspan="7">No coupons found</td>
            </tr>
          <% } %>
        
          <% coupons.forEach(coupon => { %>
            <tr>
        
              <td><%= coupon.code %></td>
        
              <td><%= coupon.discountValue %><%= coupon.discountType==="percentage"? " %" : " ₹" %> </td>
        
              <td>₹ <%= coupon.maxDiscount %></td>
        
              <td>₹ <%= coupon.minPurchase %></td>
        
              <td><%= coupon.usageLimit %></td>
        
              <td>
                <%= new Date(coupon.expiryDate).toDateString() %>
              </td>
        
              <td>
                <% const isExpired = new Date() > new Date(coupon.expiryDate); %>

                <span class="status-badge 
                  <%= !coupon.isActive ? 'status-disabled' : (isExpired ? 'status-expired' : 'status-active') %>">
                
                  <%= !coupon.isActive 
                      ? "Blocked" 
                      : (isExpired ? "Expired" : "Active") %>
                
                </span>
              </td>

              <td>
              
                <% if (!isExpired) { %>
                  <button class="action-btn toggle-btn"
                    onclick="toggleCoupon('<%= coupon._id %>', <%= coupon.isActive %>)">
              
                    <%= coupon.isActive ? "Block" : "Unblock" %>
                  </button>
                <% } else { %>
                  <span style="color: gray; font-size: 12px;">Expired</span>
                <% } %>
              </td>
        
            </tr>
          <% }) %>
        
        </tbody>


      </table>
      <nav aria-label="Page Navigation">
        <ul class="pagination">
      
          <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?page=1">First</a>
          </li>
      
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>">
                <%= i %>
              </a>
            </li>
          <% } %>
      
          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= totalPages %>">Last</a>
          </li>
      
        </ul>
      </nav>
    </div>
  </div>
  
  <div id="couponModal" class="modal-overlay">
    <div class="modal-box">
      <h2>Add Coupon</h2>
  
      <form id="couponForm">

        <label>Coupon Code </label>
<input name="code" class="info-input" >
<div class="error-msg" id="codeError"></div>
<label>Discount Type</label>
<select name="discountType" class="info-input" >
  <option value="flat">Flat</option>
  <option value="percentage">percentage</option>
</select>

<label>Discount Value</label>
<input type="number" name="discountValue" class="info-input" >
<div class="error-msg" id="discountValueError"></div>

<label id="maxDiscountLabel">Maximum Discount (₹)</label>
<input type="number" name="maxDiscount" id="maxDiscountField" class="info-input">
<div class="error-msg" id="maxDiscountError"></div>

<label>Minimum Cart Amount (₹) </label>
<input type="number" name="minPurchase" class="info-input" >
<div class="error-msg" id="minPurchaseError"></div>

<label>Usage Limit </label>
<input type="number" name="usageLimit" class="info-input" >
<div class="error-msg" id="usageLimitError"></div>

<label>Validity Date </label>
<input type="date" name="expiryDate" class="info-input" >
<div class="error-msg" id="expiryDateError"></div>


        <div class="form-actions">
          <button type="button" class="btn-cancel" onclick="closeCouponModal()">Cancel</button>
          <button type="submit" class="edit-profile-btn">Save</button>
        </div>
  
      </form>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>

document.getElementById("couponForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const form = e.target;

  document.querySelectorAll(".error-msg").forEach(el => el.innerText = "");

  let isValid = true;

  const code = form.code.value.trim().toUpperCase();
  const discountType = form.discountType.value;
  const discountValue = Number(form.discountValue.value);
  const maxDiscount = Number(form.maxDiscount.value);
  const minPurchase = Number(form.minPurchase.value);
  const usageLimit = Number(form.usageLimit.value);
  const expiryDate = form.expiryDate.value;

  if (discountValue <= 0) {
  discountValueError.innerText = "Discount must be greater than 0";
  isValid = false;
}

if (minPurchase <= 0) {
  minPurchaseError.innerText = "Minimum cart amount must be greater than 0";
  isValid = false;
}

if (discountType === "percentage") {
  if (discountValue > 90) {
    discountValueError.innerText = "Percentage discount cannot be more than 90%";
    isValid = false;
  }

  if (maxDiscount <= 0) {
    maxDiscountError.innerText = "Maximum discount is required for percentage coupon";
    isValid = false;
  }

  if (maxDiscount >= minPurchase) {
    maxDiscountError.innerText = "Maximum discount must be less than minimum cart amount";
    isValid = false;
  }
}

if (discountType === "flat") {
  if (discountValue >= minPurchase) {
    discountValueError.innerText = "Flat discount must be less than minimum cart amount";
    isValid = false;
  }
}

  if (!code || code.length < 3) {
    document.getElementById("codeError").innerText = "Minimum 3 characters required";
    isValid = false;
  }

  if (discountValue <= 0) {
    document.getElementById("discountValueError").innerText = "Must be greater than 0";
    isValid = false;
  }

  if (discountType === "percentage" && discountValue > 100) {
    document.getElementById("discountValueError").innerText = "Cannot exceed 100%";
    isValid = false;
  }

  if (discountType === "percentage" && maxDiscount <= 0) {
    document.getElementById("maxDiscountError").innerText = "Required for percentage";
    isValid = false;
  }

  if (minPurchase <= 0) {
    document.getElementById("minPurchaseError").innerText = "Must be greater than 0";
    isValid = false;
  }

  if (usageLimit <= 0) {
    document.getElementById("usageLimitError").innerText = "Must be greater than 0";
    isValid = false;
  }

  if (!expiryDate) {
    document.getElementById("expiryDateError").innerText = "Select a valid date";
    isValid = false;
  }

  if (!isValid) return;

  const data = {
    code,
    discountType,
    discountValue,
    maxDiscount,
    minPurchase,
    usageLimit,
    expiryDate
  };

  const res = await fetch("/admin/coupons/add", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(data)
  });

  const result = await res.json();

  if (result.success) {
    Swal.fire("Success", "Coupon added successfully", "success").then(() => {
      location.reload();
    });
  } else {
    Swal.fire("Error", result.message || "Error adding coupon", "error");
  }
});

const today = new Date().toISOString().split("T")[0];
document.querySelector("input[name='expiryDate']").setAttribute("min", today);
  
async function toggleCoupon(id, isActive) {

const action = isActive ? "Block" : "Unblock";

const confirm = await Swal.fire({
  title: `${action} Coupon?`,
  text: `Are you sure you want to ${action.toLowerCase()} this coupon?`,
  icon: "warning",
  showCancelButton: true,
  confirmButtonColor: isActive ? "#dc3545" : "#28a745",
  cancelButtonColor: "#aaa",
  confirmButtonText: `Yes, ${action} it`,
  cancelButtonText: "Cancel"
});

if (!confirm.isConfirmed) return;

try {
  const res = await fetch(`/admin/coupons/toggle/${id}`, {
    method: "PATCH"
  });

  const data = await res.json();

  if (data.success) {
    await Swal.fire({
      icon: "success",
      title: `${action}ed`,
      text: `Coupon ${action.toLowerCase()}ed successfully`,
      timer: 1500,
      showConfirmButton: false
    });

    location.reload();
  } else {
    Swal.fire("Error", "Something went wrong", "error");
  }

} catch (err) {
  Swal.fire("Error", "Server error", "error");
}
}
  
  async function deleteCoupon(id){
    const confirm = await Swal.fire({
      title: "Delete Coupon?",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#dc3545"
    });
  
    if(!confirm.isConfirmed) return;
  
    const res = await fetch(`/admin/coupons/delete/${id}`, {
      method: "DELETE"
    });
  
    const data = await res.json();
    if(data.success){
      location.reload();
    }
  }

function openCouponModal() {
  document.getElementById("couponModal").style.display = "flex";
}

function closeCouponModal() {
  document.getElementById("couponModal").style.display = "none";
  document.getElementById("couponForm").reset();
}  

const discountType = document.querySelector('select[name="discountType"]');
const maxField = document.getElementById("maxDiscountField");
const maxLabel = document.getElementById("maxDiscountLabel");

function toggleMaxDiscount() {
  if (discountType.value === "flat") {
    maxField.style.display = "none";
    maxLabel.style.display = "none";
    maxField.required = false;
    maxField.value = "";
  } else {
    maxField.style.display = "block";
    maxLabel.style.display = "block";
    maxField.required = true;
  }
}

discountType.addEventListener("change", toggleMaxDiscount);

window.addEventListener("load", toggleMaxDiscount);


  </script>
  
  <%- include("../partials/admin/footer") %>