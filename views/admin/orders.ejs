<%- include("../partials/admin/header", { 
  title: "Orders",
  adminName: typeof adminName !== "undefined" ? adminName : "Admin",
  activeMenu: "orders"
}) %>

<style>
.dashboard-content {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20px;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.content-header h1 {
  font-size: 28px;
  font-weight: 600;
  color: #333;
}

.table-order {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 4px rgba(0,0,0,.05);
}

.table-order table {
  width: 100%;
  border-collapse: collapse;
}

.table-order thead {
  background: #f9f9f9;
}

.table-order th,
.table-order td {
  padding: 16px;
  font-size: 14px;
  text-align: left;
  border-bottom: 1px solid #e5e7eb;
}

.status-badge {
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  display: inline-block;
}

.status-pending          { background:#fff3cd; color:#856404; }
.status-confirmed        { background:#d1ecf1; color:#0c5460; }
.status-shipped          { background:#cce5ff; color:#004085; }
.status-out_for_delivery { background:#e2e3ff; color:#383d7c; }
.status-delivered        { background:#d4edda; color:#155724; }
.status-cancelled        { background:#f8d7da; color:#721c24; }
.status-return_requested { background:#ffeeba; color:#856404; }
.status-returned         { background:#e2e3e5; color:#383d41; }
.status-return_rejected  { background:#f8d7da; color:#721c24; }

/* Override the global button style to not affect selects etc */
.action-btn {
  padding: 8px 14px;
  background: #007bff;
  border: none;
  color: #fff;
  border-radius: 4px;
  cursor: pointer;
  margin-right: 6px;
  font-size: 13px;
}

.action-btn:hover { opacity: .9; }

.return-btn {
  background: #ffc107;
  color: #000;
}

select.status-select {
  padding: 6px 10px;
  border-radius: 4px;
  border: 1px solid #ddd;
  font-size: 13px;
  cursor: pointer;
}

.payment-not-done {
  color: #dc3545;
  font-weight: 600;
  font-size: 13px;
}

.view-link {
  padding: 6px 12px;
  background: #17a2b8;
  color: #fff;
  border-radius: 4px;
  font-size: 12px;
  text-decoration: none;
  font-weight: 600;
}

.view-link:hover { opacity: .85; }
</style>

<div class="dashboard-content">

  <div class="content-header">
    <h1>Orders</h1>
  </div>

  <div class="table-order">
    <table>
      <thead>
        <tr>
          <th>Order ID</th>
          <th>User</th>
          <th>Product</th>
          <th>Item Status</th>
          <th>Payment</th>
          <th>Action</th>
          <th>Details</th>
        </tr>
      </thead>

      <tbody>
        <% if(!orders || orders.length === 0){ %>
          <tr>
            <td colspan="7" style="text-align:center;color:#888;">No orders found</td>
          </tr>
        <% } %>

        <% orders.forEach(order => { %>
          <% order.items.forEach(item => {
            const productId  = item.productId?._id || item.productId;
            const productName = item.productId?.product_name || item.productName || "Product";
          %>

            <tr>
              <td><strong><%= order.orderId %></strong></td>
              <td><%= order.userId?.fullname || "User" %></td>
              <td><%= productName %></td>

              <!-- ITEM STATUS BADGE -->
              <td>
                <span class="status-badge status-<%= item.status %>">
                  <%= item.status.replace(/_/g," ").toUpperCase() %>
                </span>
              </td>

              <!-- PAYMENT STATUS -->
              <td>
                <% if(order.paymentStatus === "Success"){ %>
                  <span style="color:#155724;font-weight:600;font-size:13px;">✓ Paid</span>
                <% } else if(order.paymentStatus === "Failed"){ %>
                  <span style="color:#721c24;font-weight:600;font-size:13px;">✗ Failed</span>
                <% } else { %>
                  <span style="color:#856404;font-weight:600;font-size:13px;">⏳ Pending</span>
                <% } %>
                <div style="font-size:11px;color:#888;margin-top:3px;"><%= order.paymentMethod %></div>
              </td>

              <!-- ACTIONS -->
              <td>
                <%
                  /*
                   * Block status changes if:
                   *  - Order is not yet confirmed (payment not completed for Razorpay)
                   *  - But allow COD and WALLET orders that ARE confirmed
                   */
                  const orderReady = order.status === "confirmed" ||
                                     order.status === "shipped"   ||
                                     order.status === "delivered";
                %>

                <% if (!orderReady) { %>

                  <span class="payment-not-done">Payment Not Completed</span>

                <% } else if (item.status === "return_requested") { %>

                  <button
                    class="action-btn return-btn"
                    onclick="openReturnModal(
                      '<%= order._id %>',
                      '<%= productId %>',
                      `<%= (item.returnReason || '').replace(/`/g, "'") %>`
                    )"
                  >
                    Review Return
                  </button>

                <% } else if (item.status === "pending") { %>

                  <select
                    class="status-select"
                    onchange="updateItemStatus('<%= order._id %>','<%= productId %>',this)"
                  >
                    <option value="" selected disabled>Change</option>
                    <option value="shipped">Shipped</option>
                    <option value="cancelled">Cancelled</option>
                  </select>

                <% } else if (item.status === "shipped") { %>

                  <select
                    class="status-select"
                    onchange="updateItemStatus('<%= order._id %>','<%= productId %>',this)"
                  >
                    <option value="" selected disabled>Change</option>
                    <option value="out_for_delivery">Out for Delivery</option>
                  </select>

                <% } else if (item.status === "out_for_delivery") { %>

                  <select
                    class="status-select"
                    onchange="updateItemStatus('<%= order._id %>','<%= productId %>',this)"
                  >
                    <option value="" selected disabled>Change</option>
                    <option value="delivered">Delivered</option>
                  </select>

                <% } else { %>
                  <span style="color:#aaa;">—</span>
                <% } %>

              </td>

              <!-- VIEW DETAILS -->
              <td>
                <a href="/admin/orders/<%= order._id %>" class="view-link">
                  View Details
                </a>
              </td>

            </tr>

          <% }) %>
        <% }) %>

      </tbody>
    </table>

    <!-- PAGINATION -->
    <div class="container mt-3">
      <nav aria-label="Page Navigation">
        <ul class="pagination">

          <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?page=1&limit=<%= limit %>">First</a>
          </li>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>&limit=<%= limit %>"><%= i %></a>
            </li>
          <% } %>

          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= totalPages %>&limit=<%= limit %>">Last</a>
          </li>

        </ul>
      </nav>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

/* ── Update item status ── */
async function updateItemStatus(orderId, productId, selectEl) {
  const status = selectEl.value;
  if (!status) return;

  const result = await Swal.fire({
    title: "Change Order Status?",
    text: `Change status to "${status.replace(/_/g, " ").toUpperCase()}"?`,
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#3085d6",
    cancelButtonColor: "#aaa",
    confirmButtonText: "Yes, update",
    cancelButtonText: "Cancel"
  });

  if (!result.isConfirmed) {
    // Reset select so it shows "Change" again
    selectEl.value = "";
    return;
  }

  try {
    const res  = await fetch("/admin/orders/update-item-status", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ orderId, productId, status })
    });
    const data = await res.json();

    if (data.success) {
      await Swal.fire({
        icon: "success",
        title: "Updated!",
        text: "Order status updated successfully",
        timer: 1200,
        showConfirmButton: false
      });
      location.reload();
    } else {
      selectEl.value = "";
      Swal.fire("Error", data.message || "Update failed", "error");
    }

  } catch (err) {
    selectEl.value = "";
    Swal.fire("Error", "Server error", "error");
  }
}

/* ── Open return review modal ── */
async function openReturnModal(orderId, productId, reason) {
  const result = await Swal.fire({
    title: "Return Request",
    html: `
      <p style="margin-bottom:10px;"><strong>Return Reason:</strong></p>
      <div style="
        background:#f8f9fa;
        padding:10px;
        border-radius:6px;
        font-size:14px;
        color:#333;
        text-align:left;
      ">
        ${reason || "No reason provided"}
      </div>
    `,
    icon: "question",
    showCancelButton: true,
    showDenyButton: true,
    confirmButtonText: "✔ Approve",
    denyButtonText: "✘ Reject",
    confirmButtonColor: "#28a745",
    denyButtonColor: "#dc3545",
    cancelButtonText: "Close"
  });

  if (result.isConfirmed) {
    processReturn(orderId, productId, "approve");
  } else if (result.isDenied) {
    processReturn(orderId, productId, "reject");
  }
}

/* ── Process return (approve / reject) ── */
async function processReturn(orderId, productId, action) {
  try {
    const res  = await fetch("/admin/orders/process-return", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ orderId, productId, action })
    });
    const data = await res.json();

    if (data.success) {
      await Swal.fire({
        icon: "success",
        title: "Done!",
        text: `Return ${action === "approve" ? "approved" : "rejected"} successfully`,
        timer: 1200,
        showConfirmButton: false
      });
      location.reload();
    } else {
      Swal.fire("Error", data.message || "Action failed", "error");
    }
  } catch (err) {
    Swal.fire("Error", "Server error", "error");
  }
}

</script>

<%- include("../partials/admin/footer") %>
