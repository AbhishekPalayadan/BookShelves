<%- include("../partials/admin/header", { 
  title: "Orders",
  adminName: typeof adminName !== "undefined" ? adminName : "Admin",
  activeMenu: "orders"
}) %>

<style>
.dashboard-content {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20px;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.content-header h1 {
  font-size: 28px;
  font-weight: 600;
  color: #333;
}

.table-order {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 4px rgba(0,0,0,.05);
}

.table-order table {
  width: 100%;
  border-collapse: collapse;
}

.table-order thead {
  background: #f9f9f9;
}

.table-order th,
.table-order td {
  padding: 16px;
  font-size: 14px;
  text-align: left;
  border-bottom: 1px solid #e5e7eb;
}

.status-badge {
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
}

.status-pending { background:#fff3cd; color:#856404; }
.status-delivered { background:#d4edda; color:#155724; }
.status-cancelled { background:#f8d7da; color:#721c24; }

button {
  padding: 8px 14px;
  background: #007bff;
  border: none;
  color: #fff;
  border-radius: 4px;
  cursor: pointer;
  margin-right: 6px;
}

button.reject {
  background: #dc3545;
}

button:hover {
  opacity: .9;
}

select {
  padding: 6px 10px;
  border-radius: 4px;
}

.status-shipped {
  background:#cce5ff;
  color:#004085;
}

.status-out_for_delivery {
  background:#e2e3ff;
  color:#383d7c;
}

</style>

<div class="dashboard-content">

  <div class="content-header">
    <h1>Orders</h1>
  </div>

  <div class="table-order">
    <table>
      <thead>
        <tr>
          <th>Order ID</th>
          <th>User</th>
          <th>Product</th>
          <th>Status</th>
          <th>Action</th>
          <th>Details</th>
        </tr>
      </thead>

      <tbody>
        <% if(!orders || orders.length === 0){ %>
          <tr>
            <td colspan="6">No orders found</td>
          </tr>
        <% } %>

        <% orders.forEach(order => { %>
          <% order.items.forEach(item => { %>

            <tr>
              <td><%= order.orderId %></td>
              <td><%= order.userId?.fullname || "User" %></td>
              <td><%= item.productId?.product_name || "Product" %></td>

              <!-- STATUS -->
              <td>
                <span class="status-badge status-<%= item.status %>">
                  <%= item.status.replace(/_/g," ").toUpperCase() %>
                </span>
                
              </td>

              <!-- ACTIONS -->
              <td>
                <% if(item.status === "return_requested"){ %>
                  
                  <button
                    style="background:#ffc107;color:#000;"
                    onclick="openReturnModal(
                      '<%= order._id %>',
                      '<%= item.productId._id %>',
                      `<%= item.returnReason %>`
                    )"
                  >
                    Return Request
                  </button>
              
                <% } else if(item.status === "pending"){ %>
              
                  <select onchange="updateItemStatus(
                    '<%= order._id %>',
                    '<%= item.productId._id %>',
                    this.value
                  )">
                    <option selected disabled>Change</option>
                    <option value="shipped">Shipped</option>
                    <option value="cancelled">Cancelled</option>
                  </select>
              
                <% } else if(item.status === "shipped"){ %>
              
                  <select onchange="updateItemStatus(
                    '<%= order._id %>',
                    '<%= item.productId._id %>',
                    this.value
                  )">
                    <option selected disabled>Change</option>
                    <option value="out_for_delivery">Out for delivery</option>
                  </select>
              
                <% } else if(item.status === "out_for_delivery"){ %>
              
                  <select onchange="updateItemStatus(
                    '<%= order._id %>',
                    '<%= item.productId._id %>',
                    this.value
                  )">
                    <option selected disabled>Change</option>
                    <option value="delivered">Delivered</option>
                  </select>
              
                <% } else { %>
                  —
                <% } %>
              </td>
              
              
              <td>
                <a 
                  href="/admin/orders/<%= order._id %>"
                  style="
                    padding:6px 12px;
                    background:#17a2b8;
                    color:#fff;
                    border-radius:4px;
                    font-size:12px;
                    text-decoration:none;
                    font-weight:600;
                  "
                >
                  View Details
                </a>
              </td>
              
            </tr>

          <% }) %>
        <% }) %>
        
      </tbody>
    </table>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
async function updateItemStatus(orderId, productId, status) {

const result = await Swal.fire({
  title: "Change Order Status?",
  text: `Change status to "${status.replace(/_/g, " ").toUpperCase()}"`,
  icon: "warning",
  showCancelButton: true,
  confirmButtonColor: "#3085d6",
  cancelButtonColor: "#aaa",
  confirmButtonText: "Yes, update",
  cancelButtonText: "Cancel"
});

if (!result.isConfirmed) return;

try {
  const res = await fetch("/admin/orders/update-item-status", {
    method: "PATCH",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ orderId, productId, status })
  });

  const data = await res.json();

  if (data.success) {
    await Swal.fire({
      icon: "success",
      title: "Updated!",
      text: "Order status updated successfully",
      timer: 1200,
      showConfirmButton: false
    });
    location.reload();
  } else {
    Swal.fire("Error", data.message || "Update failed", "error");
  }

} catch (err) {
  Swal.fire("Error", "Server error", "error");
}
}
async function handleReturn(orderId, productId, action, reason) {

const result = await Swal.fire({
  title: action === "approve" ? "Approve Return?" : "Reject Return?",
  html: `
    <p><strong>Return Reason:</strong></p>
    <p style="margin-top:6px;color:#555">${reason || "No reason provided"}</p>
  `,
  icon: "warning",
  showCancelButton: true,
  confirmButtonColor: action === "approve" ? "#28a745" : "#dc3545",
  cancelButtonColor: "#aaa",
  confirmButtonText: action === "approve" ? "Approve" : "Reject",
  cancelButtonText: "Cancel"
});

if (!result.isConfirmed) return;

try {
  const res = await fetch("/admin/orders/process-return", {
    method: "PATCH",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ orderId, productId, action })
  });

  const data = await res.json();

  if (data.success) {
    await Swal.fire({
      icon: "success",
      title: "Done!",
      text: `Return ${action === "approve" ? "approved" : "rejected"} successfully`,
      timer: 1300,
      showConfirmButton: false
    });
    location.reload();
  } else {
    Swal.fire("Error", data.message || "Action failed", "error");
  }

} catch (err) {
  Swal.fire("Error", "Server error", "error");
}
}


async function openReturnModal(orderId, productId, reason) {

const result = await Swal.fire({
  title: "Return Request",
  html: `
    <p style="margin-bottom:10px;"><strong>Return Reason:</strong></p>
    <div style="
      background:#f8f9fa;
      padding:10px;
      border-radius:6px;
      font-size:14px;
      color:#333;
    ">
      ${reason || "No reason provided"}
    </div>
  `,
  icon: "warning",
  showCancelButton: true,
  showDenyButton: true,
  confirmButtonText: "Approve",
  denyButtonText: "Reject",
  confirmButtonColor: "#28a745",
  denyButtonColor: "#dc3545",
  cancelButtonText: "Close"
});

if (result.isConfirmed) {
  processReturn(orderId, productId, "approve");
}

if (result.isDenied) {
  processReturn(orderId, productId, "reject");
}
}

async function processReturn(orderId, productId, action) {
try {
  const res = await fetch("/admin/orders/process-return", {
    method: "PATCH",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ orderId, productId, action })
  });

  const data = await res.json();

  if (data.success) {
    await Swal.fire({
      icon: "success",
      title: "Success",
      text: `Return ${action === "approve" ? "approved" : "rejected"} successfully`,
      timer: 1200,
      showConfirmButton: false
    });
    location.reload();
  } else {
    Swal.fire("Error", data.message || "Action failed", "error");
  }
} catch (err) {
  Swal.fire("Error", "Server error", "error");
}
}
</script>

<%- include("../partials/admin/footer") %>
