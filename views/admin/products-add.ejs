<%- include("../partials/admin/header", { title: "Edit Product", adminName: "Admin", activeMenu: "products" }) %>

<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<style>
.edit-wrapper { padding:20px 17px; }
.product-card { background:#fff; padding:22px; border-radius:10px; border:1px solid #e6e6e6; display:flex; gap:30px; flex-wrap:wrap; }
.left-column { width:280px; min-width:220px; }
.main-preview { width:100%; height:280px; border-radius:12px; background:#f7f7f7; border:2px dashed #ddd; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
.main-preview img { max-width:100%; max-height:100%; object-fit:contain; cursor:pointer; display:block; }
.placeholder { text-align:center; color:#888; }
.select-btn { margin-top:12px; width:100%; padding:11px; border:2px solid #888; border-radius:8px; background:#fff; font-weight:600; cursor:pointer; }
.thumbs { margin-top:12px; display:flex; gap:8px; flex-wrap:wrap; }
.thumb { width:60px; height:60px; border-radius:8px; border:1px solid #ddd; overflow:hidden; position:relative; cursor:pointer; }
.thumb img { width:100%; height:100%; object-fit:cover; display:block; }
.thumb .rm { position:absolute; top:6px; right:6px; background:rgba(0,0,0,.7); color:#fff; border:none; width:22px; height:22px; border-radius:50%; cursor:pointer; }
.main-crop-btn { position:absolute; bottom:12px; right:12px; background:#4caf50; color:#fff; border:none; padding:8px 12px; border-radius:6px; cursor:pointer; z-index:30; font-weight:600; }
.cropper-container img { max-width:none !important; }
.right-column { flex:1; display:grid; grid-template-columns:repeat(2,1fr); gap:18px; min-width:320px; }
.form-field { display:flex; flex-direction:column; }
.form-field input, .form-field textarea, .form-field select { padding:10px; border:1px solid #ccc; border-radius:8px; }
.submit-btn { grid-column:1 / -1; padding:12px; background:#ff3b3b; color:#fff; border:none; border-radius:8px; font-weight:700; cursor:pointer; margin-top:8px; }
.error-message { color:red; font-size:12px; margin:4px 0 0; }
</style>

<div class="edit-wrapper">
  <div class="content-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px;">
    <h1 style="font-size:28px; font-weight:600; color:#333;">Edit Product</h1>
  </div>

  <div class="product-card">
    <div class="left-column">
      <div class="main-preview">
        <img id="imgViewMain" src="" alt="Main preview" style="display:none;">
        <div id="placeholderBlock" class="placeholder">
          <i class="fa-solid fa-image" style="font-size:56px; display:block; margin-bottom:8px;"></i>
          <div style="font-weight:600">Product Image</div>
          <div style="font-size:13px; color:#999;">(No image selected)</div>
        </div>
        <button id="mainCropBtn" class="main-crop-btn" type="button" style="display:none;">Crop</button>
      </div>

      <input type="file" id="input1" accept="image/*" multiple style="display:none;">
      <button type="button" class="select-btn" onclick="document.getElementById('input1').click()">Select Images (max 4)</button>

      <div id="addedImagesContainer" class="thumbs"></div>
    </div>

    <div class="right-column">
      <div class="form-field">
        <label>Product Name</label>
        <input id="f_productName" type="text" name="productName" value="<%= product.product_name || product.productName || '' %>">
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Author</label>
        <input id="f_author" type="text" name="author" value="<%= product.author || '' %>">
        <p class="error-message"></p>
      </div>

      <div class="form-field" style="grid-column:1 / -1;">
        <label>Description</label>
        <textarea id="f_description" name="description" rows="4"><%= product.description || '' %></textarea>
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Publisher</label>
        <input id="f_publisher" type="text" name="publisher" value="<%= product.publisher || '' %>">
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Published Date</label>
        <input 
          id="f_publishedDate" 
          type="date" 
          name="publishedDate" 
          value="<%= product.published_date ? new Date(product.published_date).toISOString().split('T')[0] : (product.publishedDate ? new Date(product.publishedDate).toISOString().split('T')[0] : '') %>"
        >
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Category</label>
        <select id="f_category" name="category">
          <% cat.forEach(c => { %>
            <option 
              value="<%= c._id %>" 
              <%= String(c._id) === String(product.category_id || product.category) ? 'selected' : '' %>>
              <%= c.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-field">
        <label>Stock Quantity</label>
        <input id="f_stockQuantity" type="number" name="stockQuantity" value="<%= product.stock || product.stockQuantity || 0 %>" min="0">
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Page Count</label>
        <input id="f_pageCount" type="number" name="pageCount" value="<%= product.page_count || product.pageCount || '' %>">
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Language</label>
        <input id="f_language" type="text" name="language" value="<%= product.language || '' %>">
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Regular Price</label>
        <input id="f_regularPrice" type="number" name="regularPrice" value="<%= product.regular_price || product.regularPrice || '' %>">
        <p class="error-message"></p>
      </div>

      <div class="form-field">
        <label>Sale Price</label>
        <input id="f_salePrice" type="number" name="salePrice" value="<%= product.sale_price || product.salePrice || '' %>">
        <p class="error-message"></p>
      </div>

      <button id="saveBtn" type="button" class="submit-btn">Save Changes</button>
    </div>
  </div>
</div>

<div id="cropModal" style="position:fixed; inset:0; background:rgba(0,0,0,.65); display:none; justify-content:center; align-items:center; z-index:9999;">
  <div style="width:90%; max-width:920px; background:#fff; padding:14px; border-radius:10px;">
    <h3 style="margin:6px 0 12px;">Crop Image</h3>
    <div style="max-height:72vh; overflow:auto;">
      <img id="cropImage" src="" style="max-width:100%; display:block; margin:0 auto;">
    </div>
    <div style="text-align:right; margin-top:12px;">
      <button id="cancelCrop" type="button" style="padding:8px 12px; border-radius:6px; background:#ccc; border:none; margin-right:8px;">Cancel</button>
      <button id="applyCrop" type="button" style="padding:8px 12px; border-radius:6px; background:#4caf50; color:#fff; border:none;">Apply Crop</button>
    </div>
  </div>
</div>

<script>
const currentPage = "<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>";

const existingImages = <%- JSON.stringify(product.images || []) %>;
let keptExisting = [...existingImages];

const MAX_FILES = 4;

const input1 = document.getElementById("input1");
const addedImagesContainer = document.getElementById("addedImagesContainer");
const imgViewMain = document.getElementById("imgViewMain");
const placeholderBlock = document.getElementById("placeholderBlock");
const mainCropBtn = document.getElementById("mainCropBtn");

const cropModal = document.getElementById("cropModal");
const cropImage = document.getElementById("cropImage");
const cancelCrop = document.getElementById("cancelCrop");
const applyCrop = document.getElementById("applyCrop");

let filesDT = new DataTransfer();
let mainIndex = null;
let cropper = null;

function buildCombinedList() {
  const combined = [];

  keptExisting.forEach((name, index) => {
    combined.push({
      type: "existing",
      existingIndex: index,
      name,
      url: "/uploads/product-images/" + name
    });
  });

  Array.from(filesDT.files).forEach((file, index) => {
    combined.push({
      type: "new",
      newIndex: index,
      file,
      url: URL.createObjectURL(file)
    });
  });

  return combined;
}

function renderThumbnails() {
  const combined = buildCombinedList();
  addedImagesContainer.innerHTML = "";

  if (combined.length === 0) {
    imgViewMain.style.display = "none";
    placeholderBlock.style.display = "block";
    mainCropBtn.style.display = "none";
    mainIndex = null;
    return;
  }

  if (mainIndex === null || mainIndex >= combined.length) {
    mainIndex = 0;
  }

  updateMainPreview(mainIndex);

  combined.forEach((item, idx) => {
    const div = document.createElement("div");
    div.className = "thumb";

    const img = document.createElement("img");
    img.src = item.url;
    div.appendChild(img);

    div.addEventListener("click", () => {
      mainIndex = idx;
      updateMainPreview(idx);
    });

    const rm = document.createElement("button");
    rm.type = "button";
    rm.className = "rm";
    rm.innerHTML = "&times;";
    rm.addEventListener("click", (e) => {
      e.stopPropagation();
      removeImage(idx);
    });

    div.appendChild(rm);
    addedImagesContainer.appendChild(div);
  });
}

function updateMainPreview(index) {
  const combined = buildCombinedList();
  const item = combined[index];

  if (!item) {
    imgViewMain.style.display = "none";
    placeholderBlock.style.display = "block";
    mainCropBtn.style.display = "none";
    return;
  }

  imgViewMain.src = item.url;
  imgViewMain.style.display = "block";
  placeholderBlock.style.display = "none";
  mainCropBtn.style.display = "inline-block";
}

function removeImage(index) {
  const combined = buildCombinedList();
  const item = combined[index];
  if (!item) return;

  if (item.type === "existing") {
    keptExisting.splice(item.existingIndex, 1);
  } else {
    const dt = new DataTransfer();

    Array.from(filesDT.files).forEach((file, i) => {
      if (i !== item.newIndex) {
        dt.items.add(file);
      }
    });

    filesDT = dt;
    input1.files = filesDT.files;
  }

  const newLength = buildCombinedList().length;

  if (newLength === 0) {
    mainIndex = null;
  } else if (mainIndex >= newLength) {
    mainIndex = 0;
  }

  renderThumbnails();
}

input1.addEventListener("change", (e) => {
  const selected = Array.from(e.target.files || []);
  const currentCount = keptExisting.length + filesDT.files.length;
  const space = MAX_FILES - currentCount;

  if (space <= 0) {
    alert("Maximum 4 images allowed");
    input1.value = "";
    return;
  }

  if (selected.length > space) {
    alert("You can add only " + space + " more image(s)");
    selected.splice(space);
  }

  selected.forEach(file => {
    filesDT.items.add(file);
  });

  input1.files = filesDT.files;

  if (mainIndex === null) {
    mainIndex = 0;
  }

  renderThumbnails();
});

function startCropper(src, type, index) {
  cropModal.style.display = "flex";

  if (cropper) {
    cropper.destroy();
    cropper = null;
  }

  delete cropModal.dataset.existingIndex;
  delete cropModal.dataset.newIndex;

  cropModal.dataset[type] = index;

  cropImage.onload = function () {
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }

    cropper = new Cropper(cropImage, {
      viewMode: 1,
      autoCropArea: 1,
      movable: true,
      zoomable: true,
      aspectRatio: 3 / 4
    });
  };

  cropImage.src = src;
}

function openCropper(index) {
  const combined = buildCombinedList();
  const item = combined[index];
  if (!item) return;

  if (item.type === "existing") {
    startCropper(item.url, "existingIndex", item.existingIndex);
  } else {
    startCropper(item.url, "newIndex", item.newIndex);
  }
}

imgViewMain.addEventListener("click", () => {
  if (mainIndex !== null) {
    openCropper(mainIndex);
  }
});

mainCropBtn.addEventListener("click", () => {
  if (mainIndex !== null) {
    openCropper(mainIndex);
  }
});

applyCrop.addEventListener("click", () => {
  if (!cropper) return;

  const existingIndex = cropModal.dataset.existingIndex;
  const newIndex = cropModal.dataset.newIndex;

  cropper.getCroppedCanvas({
    width: 600,
    height: 800
  }).toBlob((blob) => {
    if (!blob) {
      alert("Crop failed");
      return;
    }

    const croppedFile = new File(
      [blob],
      "cropped_" + Date.now() + ".png",
      { type: "image/png" }
    );

    if (existingIndex !== undefined) {
      keptExisting.splice(Number(existingIndex), 1);
      filesDT.items.add(croppedFile);
    }

    if (newIndex !== undefined) {
      const dt = new DataTransfer();

      Array.from(filesDT.files).forEach((file, i) => {
        if (i === Number(newIndex)) {
          dt.items.add(croppedFile);
        } else {
          dt.items.add(file);
        }
      });

      filesDT = dt;
    }

    input1.files = filesDT.files;

    cropper.destroy();
    cropper = null;

    cropModal.style.display = "none";
    cropImage.src = "";

    delete cropModal.dataset.existingIndex;
    delete cropModal.dataset.newIndex;

    mainIndex = 0;
    renderThumbnails();
  }, "image/png");
});

cancelCrop.addEventListener("click", () => {
  if (cropper) {
    cropper.destroy();
    cropper = null;
  }

  cropModal.style.display = "none";
  cropImage.src = "";

  delete cropModal.dataset.existingIndex;
  delete cropModal.dataset.newIndex;
});

function clearErrors() {
  document.querySelectorAll(".error-message").forEach(el => {
    el.innerText = "";
  });
}

function showError(id, message) {
  const field = document.getElementById(id);
  const errorTag = field.parentElement.querySelector(".error-message");
  if (errorTag) errorTag.innerText = message;
}

document.getElementById("saveBtn").addEventListener("click", async (e) => {
  e.preventDefault();
  clearErrors();

  let isValid = true;

  const productName = document.getElementById("f_productName").value.trim();
  const author = document.getElementById("f_author").value.trim();
  const description = document.getElementById("f_description").value.trim();
  const publisher = document.getElementById("f_publisher").value.trim();
  const publishedDate = document.getElementById("f_publishedDate").value.trim();
  const stockQuantity = document.getElementById("f_stockQuantity").value.trim();
  const pageCount = document.getElementById("f_pageCount").value.trim();
  const language = document.getElementById("f_language").value.trim();
  const regularPrice = document.getElementById("f_regularPrice").value.trim();
  const salePrice = document.getElementById("f_salePrice").value.trim();

  if (!productName) {
    showError("f_productName", "Product name is required");
    isValid = false;
  }

  if (!author) {
    showError("f_author", "Author is required");
    isValid = false;
  }

  if (!description) {
    showError("f_description", "Description is required");
    isValid = false;
  }

  if (!publisher) {
    showError("f_publisher", "Publisher is required");
    isValid = false;
  }

  if (!publishedDate) {
    showError("f_publishedDate", "Published date is required");
    isValid = false;
  }

  if (!stockQuantity || Number(stockQuantity) < 0) {
    showError("f_stockQuantity", "Stock must be 0 or greater");
    isValid = false;
  }

  if (!pageCount || Number(pageCount) <= 0) {
    showError("f_pageCount", "Page count must be greater than 0");
    isValid = false;
  }

  if (!language) {
    showError("f_language", "Language is required");
    isValid = false;
  }

  if (!regularPrice || Number(regularPrice) <= 0) {
    showError("f_regularPrice", "Regular price must be greater than 0");
    isValid = false;
  }

  if (salePrice && Number(salePrice) > Number(regularPrice)) {
    showError("f_salePrice", "Sale price cannot be greater than regular price");
    isValid = false;
  }

  const totalImages = keptExisting.length + filesDT.files.length;

  if (totalImages === 0) {
    alert("At least one image is required");
    isValid = false;
  }

  if (totalImages > MAX_FILES) {
    alert("Maximum 4 images allowed");
    isValid = false;
  }

  if (!isValid) return;

  const fd = new FormData();

  fd.append("productName", productName);
  fd.append("author", author);
  fd.append("description", description);
  fd.append("publisher", publisher);
  fd.append("publishedDate", publishedDate);
  fd.append("category", document.getElementById("f_category").value);
  fd.append("stockQuantity", stockQuantity);
  fd.append("pageCount", pageCount);
  fd.append("language", language);
  fd.append("regularPrice", regularPrice);
  fd.append("salePrice", salePrice);

  keptExisting.forEach(img => {
    fd.append("keepImages", img);
  });

  Array.from(filesDT.files).forEach(file => {
    fd.append("images", file, file.name);
  });

  try {
    const res = await fetch("/admin/editProducts/<%= product._id %>?page=" + currentPage, {
      method: "POST",
      body: fd
    });

    if (res.redirected) {
      window.location.href = res.url;
      return;
    }

    if (!res.ok) {
      const text = await res.text();
      alert("Update failed: " + text);
      return;
    }

    window.location.href = "/admin/products?page=" + currentPage;
  } catch (error) {
    console.error(error);
    alert("Network error while updating product");
  }
});

document.getElementById("f_stockQuantity").addEventListener("input", function () {
  if (Number(this.value) < 0) {
    this.value = 0;
  }
});

document.addEventListener("DOMContentLoaded", () => {
  renderThumbnails();
});
</script>

<%- include("../partials/admin/footer") %>