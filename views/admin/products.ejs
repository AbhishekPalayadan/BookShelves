<%- include("../partials/admin/header", { title: "Products" , adminName: typeof adminName !=="undefined" ? adminName
    : "Admin" , activeMenu: activeMenu }) %>

    <div class="dashboard-content" style="padding: 20px 17px;">



        <div class="content-header"
        style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
    
        <h1 style="font-size:28px; font-weight:600; color:#333;">Products</h1>
    
        <div style="display:flex; align-items:center; gap:10px;">
    
        
            <form action="/admin/products" method="GET" style="display:flex; gap:8px;">
                <input 
                    type="text" 
                    name="search" 
                    placeholder="Search products..." 
                    value="<%= query.search || '' %>"
                    style="padding:10px; border:1px solid #ccc; border-radius:5px;"
                >
                <button type="submit" 
                    style="padding:10px 14px; border:none; background:#1e90ff; color:white; border-radius:5px;">
                    Search
                </button>
            </form>
    
           
            <a href="/admin/addProducts"
                style="background:#ff4757; padding:10px 18px; color:white; border-radius:6px; text-decoration:none;">
                Add Product
            </a>
    
        </div>
    </div>
    

        <div class="product-page-container">

    <table class="product-page-table">

        <thead>
            <tr>
                <th>Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            <% data.forEach(product => { %>
            <tr>
                <td>
                    <img 
                        class="product-page-img"
                        src="<%= product.images?.length > 0 
                            ? '/uploads/product-images/' + product.images[0] 
                            : '/images/no-image.png' %>"
                    >
                </td>

                <td class="product-page-name">
                    <%= product.product_name %>
                </td>

                <td><%= product.category_id ? product.category_id.name : "" %></td>

                <td>₹ <%= product.sale_price %></td>

                <td style="color: <%= product.stock<= '10' ? 'red' : 'none' %>;"><%= product.stock %></td>

                <td style=" color:<%= product.stock<=0 ? 'Red' : product.isDeleted ? 'red' : 'green' %>">
                    <%= product.stock<=0 ? 'Out of Stock' : product.isDeleted ? 'blocked' : 'active' %>
                </td>

                <td>
                    <div class="product-page-actions">

                        <i class="fa-solid fa-pen-to-square product-page-edit"
                            onclick="window.location.href='/admin/editProducts/<%= product._id %>?page=<%= currentPage %>'">
                        </i>

                        <i>
                            <label class="toggle-switch">
                                <input type="checkbox"
                                    <%= product.isDeleted ? '' : 'checked' %>
                                    onchange="changeProductStatus('<%= product._id %>', this.checked)">
                                <span class="slider"></span>
                            </label>
                        </i>
                        <!-- OFFER BUTTON -->
<% if(product.offerPercentage && product.offerPercentage > 0){ %>

    <!-- REMOVE OFFER BUTTON -->
    <i class="fa-solid fa-xmark"
       style="cursor:pointer; color:red;"
       onclick="removeProductOffer('<%= product._id %>')"
       title="Remove Offer">
    </i>
  
  <% } else { %>
  
    <!-- ADD OFFER BUTTON -->
    <i class="fa-solid fa-tag"
       style="cursor:pointer; color:#ff9800;"
       onclick="openProductOfferModal('<%= product._id %>')"
       title="Add Offer">
    </i>
  
  <% } %>
                        <!-- <i class="fa-solid fa-trash product-page-delete"
                            onclick="confirmDelete('<%= product._id %>')">
                        </i> -->

                    </div>
                </td>
            </tr>
            <% }) %>
        </tbody>

    </table>

</div>




        <nav aria-label="Page Navigation">
            <ul class="pagination">

                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=1">First</a>
                </li>

                <% for (let i=1; i <=totalPages; i++) { %>
                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="?page=<%= i %>">
                            <%= i %>
                        </a>
                    </li>
                    <% } %>

                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= totalPages %>">Last</a>
                        </li>

            </ul>
        </nav>



    </div>
    <div id="offerModal" class="modal">
        <div class="inner-modal">
          <span onclick="closeOfferModal()" class="close">&times;</span>
      
          <h2>Set Offer</h2>
      
          <input type="hidden" id="offerId">
          <input type="hidden" id="offerType">
      
          <div style="margin-bottom:15px;">
            <label>Discount %</label>
            <input type="number" id="discountInput" min="1" max="90"
                   style="width:100%; padding:10px;">
            <p id="discountError" style="color:red; font-size:13px;"></p>
          </div>
          
          <div style="margin-bottom:15px;">
            <label>Start Date</label>
            <input type="date" id="startDate"
                   style="width:100%; padding:10px;">
            <p id="startDateError" style="color:red; font-size:13px;"></p>
          </div>
          
          <div style="margin-bottom:15px;">
            <label>End Date</label>
            <input type="date" id="endDate"
                   style="width:100%; padding:10px;">
            <p id="endDateError" style="color:red; font-size:13px;"></p>
          </div>
      
          <button onclick="saveOffer()"
              style="background:#ff4757; color:white; padding:10px 18px;
                     border:none; border-radius:6px;">
            Save Offer
          </button>
      
        </div>
      </div>

<script>
function confirmDelete(productId) {
    Swal.fire({
        title: "Are you sure?",
        text: "This product will be deleted",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#ff4757",
        cancelButtonColor: "#6c757d",
        confirmButtonText: "Yes, delete it!"
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/admin/deleteProduct/${productId}`;
        }
    });
}

function changeProductStatus(id, isChecked) {
    const action = isChecked ? "active" : "block";

    Swal.fire({
        title: `${action} this product?`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: `Yes, ${action}`,
    }).then((res) => {
        if (res.isConfirmed) {
            window.location.href = `/admin/productStatus?id=${id}&status=${isChecked}`;
        } else {
            location.reload();
        }
    });
}
function openProductOfferModal(id) {
  document.getElementById("offerId").value = id;
  document.getElementById("offerType").value = "product";

  document.getElementById("discountInput").value = "";
  document.getElementById("startDate").value = "";
  document.getElementById("endDate").value = "";

  clearOfferErrors();

  document.getElementById("offerModal").style.display = "block";
}

function closeOfferModal() {
  clearOfferErrors();
  document.getElementById("offerModal").style.display = "none";
}


async function saveOffer() {
  clearOfferErrors();

  const id = document.getElementById("offerId").value;
  const type = document.getElementById("offerType").value;

  const discountInput = document.getElementById("discountInput");
  const startDateInput = document.getElementById("startDate");
  const endDateInput = document.getElementById("endDate");

  const discountValue = discountInput.value;
  const startDateValue = startDateInput.value;
  const endDateValue = endDateInput.value;

  if (!id) {
    Swal.fire("Error", "Invalid product selected", "error");
    return;
  }

  if (type !== "product") {
    Swal.fire("Error", "Invalid offer type", "error");
    return;
  }

  const errors = validateOffer(discountValue, startDateValue, endDateValue);

  if (errors.discount) {
    document.getElementById("discountError").innerText = errors.discount;
  }

  if (errors.startDate) {
    document.getElementById("startDateError").innerText = errors.startDate;
  }

  if (errors.endDate) {
    document.getElementById("endDateError").innerText = errors.endDate;
  }

  if (Object.keys(errors).length > 0) return;

  try {
    const res = await fetch(`/admin/setProductOffer/${id}`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        discount: Number(discountValue),
        startDate: startDateValue,
        endDate: endDateValue
      })
    });

    const data = await res.json();

    if (!res.ok || !data.success) {
      Swal.fire("Error", data.message || "Could not add product offer", "error");
      return;
    }

    Swal.fire({
      icon: "success",
      title: "Offer Added",
      text: "Product offer added successfully"
    }).then(() => location.reload());

  } catch (error) {
    Swal.fire("Error", "Server error. Please try again.", "error");
  }
}

function clearOfferErrors() {
  document.getElementById("discountError").innerText = "";
  document.getElementById("startDateError").innerText = "";
  document.getElementById("endDateError").innerText = "";
}

function validateOffer(discountValue, startDateValue, endDateValue) {
  const errors = {};

  const discount = Number(discountValue);

  if (!discountValue) {
    errors.discount = "Discount is required";
  } else if (isNaN(discount)) {
    errors.discount = "Discount must be a number";
  } else if (!Number.isInteger(discount)) {
    errors.discount = "Discount must be a whole number";
  } else if (discount < 1) {
    errors.discount = "Discount must be at least 1%";
  } else if (discount > 90) {
    errors.discount = "Discount cannot be more than 90%";
  }

  if (!startDateValue) {
    errors.startDate = "Start date is required";
  }

  if (!endDateValue) {
    errors.endDate = "End date is required";
  }

  const today = new Date();
  today.setHours(0, 0, 0, 0);

  const startDate = new Date(startDateValue);
  const endDate = new Date(endDateValue);

  if (startDateValue && isNaN(startDate.getTime())) {
    errors.startDate = "Invalid start date";
  }

  if (endDateValue && isNaN(endDate.getTime())) {
    errors.endDate = "Invalid end date";
  }

  if (!errors.startDate && startDate < today) {
    errors.startDate = "Start date cannot be in the past";
  }

  if (!errors.startDate && !errors.endDate && endDate <= startDate) {
    errors.endDate = "End date must be after start date";
  }

  return errors;
}



async function removeProductOffer(id){
  Swal.fire({
    title:"Remove offer?",
    icon:"warning",
    showCancelButton:true
  }).then(async(result)=>{
    if(result.isConfirmed){
      await fetch(`/admin/removeProductOffer/${id}`);
      location.reload();
    }
  });
}

async function removeCategoryOffer(id){
  Swal.fire({
    title:"Remove offer?",
    icon:"warning",
    showCancelButton:true
  }).then(async(result)=>{
    if(result.isConfirmed){
      await fetch(`/admin/removeCategoryOffer/${id}`);
      location.reload();
    }
  });
}

</script>

    <%- include("../partials/admin/footer") %>