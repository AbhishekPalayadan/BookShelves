<!DOCTYPE html>
<html lang="en">

<head>
    <style>
        .icon-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.badge {
    position: absolute;
    top: -8px;
    right: -10px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;

    background: #e53935;
    color: white;

    border-radius: 50%;
    font-size: 11px;
    font-weight: 600;

    display: flex;
    align-items: center;
    justify-content: center;

    line-height: 1;
}
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bookshelves - Book Bound</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="/css/header.css">

</head>

<body>

    <header>
        <a class="logo" href="/" style="text-decoration: none;">
            <img src="/images/book-icon.png" alt="BooksBound Logo">
            <span>Bookshelves</span>
        </a>

        <nav>
            <a href="/about">About Us</a>
            <a href="/contact">Contact</a>
            <a href="/products">Shop</a>
        </nav>
        <div class="search-login">





<div class="icons">

    <% if (user && user.fullname) { %>
        <div class="header-icons">
            <a href="/wishlist" class="icon-badge">
                <i class="fa-solid fa-heart"></i>
            
                <% if (wishlistCount > 0) { %>
                    <span class="badge"><%= wishlistCount %></span>
                <% } %>
            </a>
            
            <a href="/cart" class="icon-badge">
                <i class="fa-solid fa-cart-shopping"></i>
            
                <% if (cartCount > 0) { %>
                    <span class="badge"><%= cartCount %></span>
                <% } %>
            </a>
        <a href="/userProfile" class="header-user">
            <span class="user-name"><%= user.fullname %></span>
        
            <div class="user-avatar">
                <% if (user.profileImage) { %>
                    <img src="<%= user.profileImage %>" alt="Profile">
                <% } else { %>
                    <span class="avatar-initial">
                        <%= user.fullname.charAt(0).toUpperCase() %>
                    </span>
                <% } %>
            </div>
        </a>
        
    </div>
    <% } else { %>

        <div class="auth-links">
            <!-- <a href="/signup" class="auth-btn ghost">Sign Up</a> -->
            <a href="/login" class="auth-btn glow">Login</a>
        </div>
        
        

    <% } %>

</div>


        </div>
    </header>
