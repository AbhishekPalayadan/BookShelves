<%-include("../../views/partials/user/header")%>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>

<style>
    .explore-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 28px;
    background: #000000;
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    border-radius: 30px;
    text-decoration: none;
    transition: all 0.3s ease;
}

.explore-btn:hover {
    color: #000000;
    background: #ffffff;
    transform: translateY(-3px);
}
</style>

<section class="hero">
    <img src="/images/book-banner6.jpg" class="hero-banner" alt="Banner Image">

    <div class="hero-text">
        <h1>Book Bound</h1>
        <p>Where Every Story<br>Finds a Reader</p>

        <a href="/products" class="explore-btn">
            <i class="fa-solid fa-book"></i> Explore All Books
        </a>
    </div>
</section>



<section class="top-picks">
<div class="section-title">
    <div class="line"></div>
    <h2>Top Picks</h2>
    <span class="section-title-2">Editor's Choice</span>
    <a href="/products" class="see-all">View all</a>
</div>

    <div class="books-grid">
        <% if (topPicks && topPicks.length > 0) { %>
            <% topPicks.forEach(product => { %>

                <%- include("../partials/user/productCard", { product }) %>

            <% }) %>
        <% } else { %>
            <p>No top picks available</p>
        <% } %>
    </div>
</section>






<section class="categories">
    <div class="section-title">
        <div class="line"></div>
        <h2>Categories</h2>
    </div>

    <ul class="category-list">
        <% if (categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
                <li class="category-item">
                    <a href="/products?category=<%= cat._id %>">
                        <%= cat.name %>
                    </a>
                </li>
                
            <% }) %>
        <% } else { %>
            <li>No categories available</li>
        <% } %>
    </ul>
</section>




<section class="new-arrivals">
    <div class="section-title">
        <div class="line"></div>
        <h2>Featured</h2>
        <span class="section-title-2">New Arrivals</span>
        <a href="/products" class="see-all">View all</a>
    </div>


    <div class="books-grid">
    <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>

            <%- include("../partials/user/productCard", { product }) %>

        <% }) %>
    <% } else { %>
        <p>No products found</p>
    <% } %>
</div>




</section>

