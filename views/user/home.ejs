<section class="trending-section">
    <div class="section-title">
        <div class="line"></div>
        <h2>Trending Now</h2>
        <span class="section-title-2">Popular Among Readers</span>
        <a href="/products" class="see-all">View all</a>
    </div>

    <div class="books-grid">
        <% if (trending && trending.length > 0) { %>
            <% trending.forEach(product => { %>

                <%- include("../partials/user/productCard", { product }) %>

            <% }) %>
        <% } else { %>
            <p>No trending books available</p>
        <% } %>
    </div>
</section>

<script>

    let activeToast=null;
    async function toggleWishlist(btn) {
    const productId = btn.getAttribute("data-id");
    const icon = btn.querySelector("i");

    const res = await fetch("/wishlist/toggle", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({ productId })
    });

    const data = await res.json();

    if (data.status === "added") {
        icon.classList.remove("fa-regular");
        icon.classList.add("fa-solid");
        icon.style.color = "red";
        showToast("Added to wishlist","success");
    } else if (data.status === "removed") {
        icon.classList.remove("fa-solid");
        icon.classList.add("fa-regular");
        icon.style.color = "black";
        showToast("Removed from wishlist")
    }
}

function showToast(message, type = "error") {
  if (activeToast) {
    activeToast.hideToast();
  }

  activeToast = Toastify({
    text: message,
    duration: 2000,
    gravity: "top",
    position: "center",
    style: {
      background: type === "success" ? "#2ecc71" : "#ff4757"
    }
  });

  activeToast.showToast();
}
</script>


   <%-include("../../views/partials/user/footer")%>