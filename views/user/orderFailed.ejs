<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Failed</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f6f9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .card {
            width: 100%;
            max-width: 540px;
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #e8ecf0;
            overflow: hidden;
        }

        /* ── Header band ── */
        .card-header {
            background: #c0392b;
            padding: 36px 40px 30px;
            text-align: center;
        }

        .icon-ring {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(255,255,255,0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            border: 2px solid rgba(255,255,255,0.35);
        }

        .icon-ring svg {
            width: 34px;
            height: 34px;
            stroke: #ffffff;
            stroke-width: 2.5;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .card-header h1 {
            font-size: 22px;
            font-weight: 600;
            color: #ffffff;
            letter-spacing: -0.3px;
        }

        .card-header p {
            font-size: 13px;
            color: rgba(255,255,255,0.75);
            margin-top: 6px;
        }

        /* ── Body ── */
        .card-body { padding: 28px 32px; }

        /* ── Amount highlight ── */
        .amount-badge {
            background: #fff5f5;
            border: 1px solid #f5c6c6;
            border-radius: 8px;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .amount-label {
            font-size: 13px;
            color: #7a4040;
            font-weight: 500;
        }

        .amount-value {
            font-size: 22px;
            font-weight: 700;
            color: #c0392b;
            letter-spacing: -0.5px;
        }

        /* ── Details list ── */
        .details-list {
            border: 1px solid #e8ecf0;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 13px 18px;
            font-size: 13px;
            border-bottom: 1px solid #f0f2f5;
            gap: 12px;
        }

        .detail-row:last-child { border-bottom: none; }

        .detail-label {
            color: #6b7a95;
            font-weight: 500;
            white-space: nowrap;
        }

        .detail-value {
            color: #1e2740;
            font-weight: 600;
            text-align: right;
        }

        /* ── Info strip ── */
        .info-strip {
            background: #fffbf0;
            border: 1px solid #f5d97a;
            border-radius: 8px;
            padding: 13px 18px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 28px;
            font-size: 13px;
        }

        .info-strip i {
            color: #b8860b;
            font-size: 14px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .info-strip p { color: #6b5500; line-height: 1.5; }
        .info-strip strong { color: #4a3b00; }

        /* ── Buttons ── */
        .btn-group {
            display: flex;
            gap: 12px;
        }

        .btn {
            flex: 1;
            padding: 13px 16px;
            font-size: 13px;
            font-weight: 600;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            transition: filter 0.15s ease, transform 0.1s ease;
        }

        .btn:active { transform: scale(0.98); }
        .btn:hover { filter: brightness(0.93); }
        .btn:disabled { opacity: 0.6; cursor: not-allowed; filter: none; transform: none; }

        .btn-danger {
            background: #c0392b;
            color: #ffffff;
        }

        .btn-secondary {
            background: #f0f2f5;
            color: #3a4a65;
        }

        @media (max-width: 480px) {
            .card-body { padding: 22px 18px; }
            .card-header { padding: 28px 20px 24px; }
            .btn-group { flex-direction: column; }
        }
    </style>
</head>
<body>

<%
    const finalAmt = order.pricing?.finalAmount ?? order.totalAmount ?? 0;
%>

<div class="card">

    <div class="card-header">
        <div class="icon-ring">
            <svg viewBox="0 0 24 24">
                <line x1="6" y1="6" x2="18" y2="18"></line>
                <line x1="18" y1="6" x2="6" y2="18"></line>
            </svg>
        </div>
        <h1>Payment Failed</h1>
        <p>Your payment could not be processed. Please try again.</p>
    </div>

    <div class="card-body">

        <div class="amount-badge">
            <span class="amount-label">Amount Due</span>
            <span class="amount-value">₹<%= Number(finalAmt).toFixed(2) %></span>
        </div>

        <div class="details-list">
            <div class="detail-row">
                <span class="detail-label">Order ID</span>
                <span class="detail-value">#<%= order.orderId %></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Date</span>
                <span class="detail-value">
                    <%= new Date(order.createdAt).toLocaleDateString("en-IN", { day:"numeric", month:"short", year:"numeric" }) %>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Payment Status</span>
                <span class="detail-value" style="color:#c0392b;">
                    <i class="fas fa-circle-xmark" style="font-size:12px;"></i> Failed
                </span>
            </div>
        </div>

        <div class="info-strip">
            <i class="fas fa-circle-info"></i>
            <p>No amount has been deducted. Your order is saved — you can retry payment anytime from <strong>My Orders</strong>.</p>
        </div>

        <div class="btn-group">
            <a href="/orders" class="btn btn-secondary">
                <i class="fas fa-box"></i> My Orders
            </a>
            <button id="retryBtn" onclick="retryPayment()" class="btn btn-danger">
                <i class="fas fa-rotate-right"></i> Retry Payment
            </button>
        </div>

    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
async function retryPayment() {
    const btn    = document.getElementById("retryBtn");
    const orderId = "<%= order.orderId %>";

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Please wait…';

    try {
        const razorRes  = await fetch("/create-order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ orderId })
        });
        const razorData = await razorRes.json();

        if (!razorData.success) {
            alert("Unable to initiate payment. Please try again.");
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-rotate-right"></i> Retry Payment';
            return;
        }

        const options = {
            key:      razorData.key,
            amount:   razorData.razorpayOrder.amount,
            currency: "INR",
            name:     "Bookshelves",
            description: `Order #${orderId}`,
            order_id: razorData.razorpayOrder.id,

            handler: async function (response) {
                const verifyRes  = await fetch("/verify", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ ...response, orderId })
                });
                const verifyData = await verifyRes.json();

                if (verifyData.success) {
                    window.location.href = `/order-success/${orderId}`;
                } else {
                    alert("Payment verification failed. Please contact support.");
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-rotate-right"></i> Retry Payment';
                }
            },

            modal: {
                ondismiss: function () {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-rotate-right"></i> Retry Payment';
                    window.location.href = `/order-failed/${orderId}`;
                }
            }
        };

        const rzp = new Razorpay(options);
        rzp.open();

    } catch (err) {
        console.error(err);
        alert("Something went wrong. Please try again.");
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-rotate-right"></i> Retry Payment';
    }
}
</script>

</body>
</html>
