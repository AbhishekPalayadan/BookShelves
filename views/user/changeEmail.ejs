<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <title>Change Email - Bookshelves</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    header {
      background-color: #fff;
      border-bottom: 1px solid #e0e0e0;
      padding: 20px 0;
    }

    nav {
      display: flex;
      gap: 30px;
    }

    nav a {
      text-decoration: none;
      color: #000;
      font-size: 15px;
      transition: color 0.3s;
    }

    nav a:hover {
      color: #ff4757;
    }

    .main-container {
      max-width: 1200px;
      margin: 25px auto;
      padding: 0 20px;
    }

    .breadcrumb {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      font-size: 14px;
      color: #666;
    }

    .breadcrumb a {
      color: #666;
      text-decoration: none;
    }

    .breadcrumb a:hover {
      color: #ff4757;
    }

    .breadcrumb-divider {
      margin: 0 8px;
    }

    .welcome-text {
      font-size: 16px;
      color: #333;
    }

    .welcome-text .customer-name {
      color: #ff4757;
      font-weight: 600;
    }

    .profile-layout {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 30px;
      align-items: start;
    }

    .profile-content {
      background: #fff;
      border-radius: 8px;
      padding: 40px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .profile-content h2 {
      font-size: 22px;
      margin-bottom: 25px;
      color: #333;
    }

    .info-item {
      background: #fafafa;
      padding: 16px 18px;
      border-radius: 10px;
      border: 1px solid #eee;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .info-label {
      font-size: 13px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      margin-top: 8px;
    }

    .info-input {
      width: 100%;
      font-size: 16px;
      padding: 12px 16px;
      border-radius: 6px;
      border: 1px solid #e9ecef;
      background: #ffffff;
      outline: none;
    }

    .info-input:focus {
      border-color: #ff4757;
      background: #fff;
    }

    .info-input:disabled {
      background: #f1f1f1;
      color: #777;
      cursor: not-allowed;
    }

    .form-actions {
      display: flex;
      justify-content: flex-end;
      gap: 15px;
      margin-top: 25px;
    }

    .edit-profile-btn {
      padding: 10px 24px;
      background: #ff4757;
      color: #fff;
      border: none;
      border-radius: 25px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.3s;
      text-decoration: none;
    }

    .edit-profile-btn:hover {
      background: #ff3838;
    }

    .edit-profile-btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .btn-cancel {
      padding: 10px 22px;
      border-radius: 25px;
      text-decoration: none;
      font-weight: 600;
      background: #eee;
      color: #333;
      border: none;
      cursor: pointer;
    }

    .btn-cancel:hover {
      background: #ddd;
    }

    .error {
      color: #e63946;
      font-size: 13px;
      display: block;
      font-weight: 500;
      margin-bottom: 12px;
    }

    .input-error {
      border: 1.5px solid #e63946 !important;
      background-color: #fff5f5;
    }

    .note {
      font-size: 13px;
      color: #777;
      margin-bottom: 15px;
      line-height: 1.5;
    }

    @media (max-width: 968px) {
      .profile-layout {
        grid-template-columns: 1fr;
      }

      nav {
        order: 3;
        width: 100%;
        justify-content: center;
      }
    }

    @media (max-width: 640px) {
      .profile-content {
        padding: 25px 20px;
      }

      .form-actions {
        flex-direction: column;
      }

      .edit-profile-btn,
      .btn-cancel {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>

<body>
  <%- include("../../views/partials/user/header") %>

  <div class="main-container">
    <div class="breadcrumb">
      <div>
        <a href="/">Home</a>
        <span class="breadcrumb-divider">/</span>
        <span>Change Email</span>
      </div>

      <div class="welcome-text">
        Welcome! <span class="customer-name"><%= user.fullname %></span>
      </div>
    </div>

    <div class="profile-layout">
      <%- include('../partials/user/profileSidebar', { user: user, activeMenu: 'profile' }) %>

      <main class="profile-content">
        <h2>Change Email</h2>

        <p class="note">
          Enter your new email address. We will send an OTP to the new email for verification.
        </p>

        <form id="changeEmailForm">
          <div class="info-item">
            <label class="info-label">Current Email</label>
            <input
              type="email"
              class="info-input"
              value="<%= user.email %>"
              disabled
            />

            <label class="info-label">New Email</label>
            <input
              type="email"
              id="newEmail"
              class="info-input"
              placeholder="Enter new email"
            />
            <small class="error" id="newEmailError"></small>

            <% if (user.password) { %>
              <label class="info-label">Current Password</label>
              <input
                type="password"
                id="password"
                class="info-input"
                placeholder="Enter current password"
              />
              <small class="error" id="passwordError"></small>
            <% } else { %>
              <p class="note">
                You logged in using Google, so password verification is not required.
              </p>
            <% } %>
          </div>

          <div class="form-actions">
            <a href="/userProfile" class="btn-cancel">Cancel</a>
            <button type="submit" class="edit-profile-btn" id="sendOtpBtn">
              Send OTP
            </button>
          </div>
        </form>

        <form id="otpForm" style="display:none;">
          <div class="info-item">
            <label class="info-label">Enter OTP</label>
            <input
              type="text"
              id="otp"
              class="info-input"
              placeholder="Enter 6 digit OTP"
              maxlength="6"
            />
            <small class="error" id="otpError"></small>
          </div>

          <div class="form-actions">
            <button type="button" class="btn-cancel" id="backBtn">
              Back
            </button>

            <button type="button" class="btn-cancel" id="resendOtpBtn">
              Resend OTP
            </button>

            <button type="submit" class="edit-profile-btn" id="verifyOtpBtn">
              Verify OTP
            </button>
          </div>
        </form>
      </main>
    </div>
  </div>

  <%- include("../../views/partials/user/footer") %>

  <script>
    const changeEmailForm = document.getElementById("changeEmailForm");
    const otpForm = document.getElementById("otpForm");

    const newEmailInput = document.getElementById("newEmail");
    const passwordInput = document.getElementById("password");
    const otpInput = document.getElementById("otp");

    const newEmailError = document.getElementById("newEmailError");
    const passwordError = document.getElementById("passwordError");
    const otpError = document.getElementById("otpError");

    const sendOtpBtn = document.getElementById("sendOtpBtn");
    const verifyOtpBtn = document.getElementById("verifyOtpBtn");
    const resendOtpBtn = document.getElementById("resendOtpBtn");
    const backBtn = document.getElementById("backBtn");

    let lastNewEmail = "";
    let lastPassword = "";

    function clearErrors() {
      newEmailError.innerText = "";
      otpError.innerText = "";

      if (passwordError) {
        passwordError.innerText = "";
      }

      document.querySelectorAll(".info-input").forEach(input => {
        input.classList.remove("input-error");
      });
    }

    function showError(input, errorElement, message) {
      input.classList.add("input-error");
      errorElement.innerText = message;
    }

    function isValidEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }

    async function sendOtp() {
      clearErrors();

      const newEmail = newEmailInput.value.trim().toLowerCase();
      const password = passwordInput ? passwordInput.value.trim() : "";

      let hasError = false;

      if (!newEmail) {
        showError(newEmailInput, newEmailError, "Please enter new email");
        hasError = true;
      } else if (!isValidEmail(newEmail)) {
        showError(newEmailInput, newEmailError, "Please enter a valid email");
        hasError = true;
      } else if (newEmail === "<%= user.email %>".toLowerCase()) {
        showError(newEmailInput, newEmailError, "New email cannot be same as current email");
        hasError = true;
      }

      if (passwordInput && !password) {
        showError(passwordInput, passwordError, "Please enter your current password");
        hasError = true;
      }

      if (hasError) return;

      try {
        sendOtpBtn.disabled = true;
        sendOtpBtn.innerText = "Sending...";

        const res = await fetch("/change-email/send-otp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            newEmail,
            password
          })
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: data.message || "Failed to send OTP"
          });
          return;
        }

        lastNewEmail = newEmail;
        lastPassword = password;

        Swal.fire({
          icon: "success",
          title: "OTP Sent",
          text: data.message
        });

        changeEmailForm.style.display = "none";
        otpForm.style.display = "block";

      } catch (error) {
        Swal.fire({
          icon: "error",
          title: "Error",
          text: "Something went wrong"
        });
      } finally {
        sendOtpBtn.disabled = false;
        sendOtpBtn.innerText = "Send OTP";
      }
    }

    changeEmailForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      await sendOtp();
    });

    otpForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      clearErrors();

      const otp = otpInput.value.trim();

      if (!otp) {
        showError(otpInput, otpError, "Please enter OTP");
        return;
      }

      if (!/^\d{6}$/.test(otp)) {
        showError(otpInput, otpError, "OTP must be 6 digits");
        return;
      }

      try {
        verifyOtpBtn.disabled = true;
        verifyOtpBtn.innerText = "Verifying...";

        const res = await fetch("/change-email/verify-otp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ otp })
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: data.message || "OTP verification failed"
          });
          return;
        }

        Swal.fire({
          icon: "success",
          title: "Success",
          text: data.message,
          timer: 2000,
          showConfirmButton: false
        });

        setTimeout(() => {
          window.location.href = data.redirectUrl || "/userProfile";
        }, 2000);

      } catch (error) {
        Swal.fire({
          icon: "error",
          title: "Error",
          text: "Something went wrong"
        });
      } finally {
        verifyOtpBtn.disabled = false;
        verifyOtpBtn.innerText = "Verify OTP";
      }
    });

    resendOtpBtn.addEventListener("click", async () => {
      if (!lastNewEmail) {
        Swal.fire({
          icon: "error",
          title: "Error",
          text: "Please enter email again"
        });
        return;
      }

      try {
        resendOtpBtn.disabled = true;
        resendOtpBtn.innerText = "Resending...";

        const res = await fetch("/change-email/send-otp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            newEmail: lastNewEmail,
            password: lastPassword
          })
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: data.message || "Failed to resend OTP"
          });
          return;
        }

        Swal.fire({
          icon: "success",
          title: "OTP Resent",
          text: data.message
        });

      } catch (error) {
        Swal.fire({
          icon: "error",
          title: "Error",
          text: "Something went wrong"
        });
      } finally {
        resendOtpBtn.disabled = false;
        resendOtpBtn.innerText = "Resend OTP";
      }
    });

    backBtn.addEventListener("click", () => {
      otpForm.style.display = "none";
      changeEmailForm.style.display = "block";
      otpInput.value = "";
      clearErrors();
    });
  </script>
</body>
</html>