<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Checkout - Bookshelves</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', 'Segoe UI', sans-serif;
      background-color: #f5f5f5;
      color: #333;
    }

    .main-content {
      max-width: 1200px;
      margin: 30px auto;
      padding: 0 20px;
    }

    .breadcrumb {
      font-size: 14px;
      color: #777;
      margin-bottom: 25px;
    }

    .breadcrumb a { color: #777; text-decoration: none; }
    .breadcrumb a:hover { color: #ff4757; }

    .checkout-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 30px;
    }

    .billing-section,
    .order-summary {
      background: #fff;
      padding: 30px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    h2, h3 { font-weight: 600; }

    /* ── Address ── */
    .address-card {
      border: 1px solid #ddd;
      padding: 15px;
      border-radius: 6px;
      margin-bottom: 15px;
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .address-text {
      font-size: 14px;
      line-height: 1.6;
      flex: 1;
    }

    .address-list {
      max-height: 400px;
      overflow-y: auto;
      padding-right: 5px;
    }

    .address-list::-webkit-scrollbar { width: 5px; }
    .address-list::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }

    .add-address-btn,
    .place-order-btn {
      width: 100%;
      padding: 14px;
      border: none;
      background: #ff4757;
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      border-radius: 6px;
      cursor: pointer;
      margin-top: 10px;
    }

    .add-address-btn:hover,
    .place-order-btn:hover { background: #e63946; }

    .add-address-btn-min {
      margin-top: 12px;
      padding: 8px 18px;
      border: 1px dashed #ff0000;
      background: #fff;
      color: #ff0000;
      font-size: 13px;
      font-weight: 500;
      border-radius: 22px;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .add-address-btn-min:hover { background: #fafafa; border-color: #999; color: #222; }

    .edit-btn {
      margin-left: auto;
      padding: 6px 14px;
      height: 30px;
      border: 1px solid #ff0000;
      background: #fff;
      color: #ff0000;
      font-size: 13px;
      font-weight: 500;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
    }

    .edit-btn:hover { background: #f8f8f8; border-color: #ccc; color: #222; }

    /* ── Payment ── */
    .payment-option {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 15px;
      border: 1px solid #ddd;
      border-radius: 8px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: 0.2s;
    }

    .payment-option:hover { border-color: #007bff; background: #f8f9ff; }
    .payment-option input { transform: scale(1.2); }
    .payment-content strong { font-size: 14px; }
    .payment-content p { font-size: 12px; color: #666; margin: 2px 0 0; }

    /* ── Order items ── */
    .order-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      padding: 12px 0;
      border-bottom: 1px solid #eee;
    }

    .item-img {
      width: 60px;
      height: 80px;
      object-fit: cover;
      border-radius: 6px;
    }

    .item-details { display: flex; flex-direction: column; gap: 4px; flex: 1; }
    .item-title { font-size: 14px; font-weight: 600; color: #222; }

    .price-block { display: flex; flex-direction: column; gap: 2px; }

    .price-row { display: flex; align-items: center; gap: 6px; }
    .price { font-size: 15px; font-weight: 600; color: #111; }
    .offer { font-size: 11px; color: #27ae60; font-weight: 500; }
    .old-price { font-size: 11px; color: #999; text-decoration: line-through; }
    .meta { font-size: 11px; color: #666; }

    /* ── Coupon ── */
    .coupon-container { margin: 15px 0; }

    .coupon-list {
      max-height: 220px;
      overflow-y: auto;
      padding-right: 5px;
    }

    .coupon-list::-webkit-scrollbar { width: 5px; }
    .coupon-list::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }

    .coupon-card {
      border: 1px dashed #ddd;
      padding: 10px;
      margin-bottom: 8px;
      border-radius: 6px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .coupon-code { font-weight: 700; font-size: 14px; }
    .coupon-desc { font-size: 12px; color: #777; margin-top: 2px; }

    .coupon-apply-btn {
      background: #ff4757;
      border: none;
      color: #fff;
      padding: 6px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
    }

    .coupon-apply-btn:hover { background: #e0313f; }

    .coupon-input-row {
      margin: 15px 0 20px;
      display: flex;
      gap: 8px;
    }

    .coupon-input-row input {
      flex: 1;
      padding: 9px 12px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 14px;
    }

    .coupon-input-row button {
      padding: 9px 14px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      color: #fff;
    }

    #applyCouponBtn  { background: #ff4757; }
    #removeCouponBtn { background: #888; }

    /* ── Price summary ── */
    .price-summary { padding-top: 12px; }

    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
      font-size: 14px;
    }

    .summary-row.total {
      font-size: 18px;
      font-weight: 700;
      border-top: 1px solid #eee;
      padding-top: 12px;
      margin-top: 6px;
    }

    /* ── Modal ── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .modal-box {
      background: #fff;
      width: 100%;
      max-width: 450px;
      padding: 30px;
      border-radius: 12px;
      animation: fadeIn 0.25s ease;
    }

    .modal-box label {
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 6px;
      display: block;
    }

    .info-input {
      width: 100%;
      padding: 12px;
      border-radius: 6px;
      border: 1px solid #ddd;
      margin-bottom: 10px;
    }

    .error { font-size: 12px; color: #e63946; margin-bottom: 10px; display: block; }

    .form-actions {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      margin-top: 20px;
    }

    .btn-cancel {
      padding: 10px 20px;
      border-radius: 25px;
      border: none;
      background: #eee;
      cursor: pointer;
      font-weight: 600;
    }

    .edit-profile-btn {
      padding: 10px 24px;
      border-radius: 25px;
      border: none;
      background: #ff4757;
      color: #fff;
      font-weight: 600;
      cursor: pointer;
    }

    .swal2-container { z-index: 20000 !important; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 900px) {
      .checkout-layout { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>

<%- include("../../views/partials/user/header", { user }) %>

<div class="main-content">

  <div class="breadcrumb">
    <a href="/">Home</a> / <a href="/cart">Cart</a> / Checkout
  </div>

  <div class="checkout-layout">

    <!-- ═══════════════════════════════════ -->
    <!--  BILLING SECTION                   -->
    <!-- ═══════════════════════════════════ -->
    <div class="billing-section">
      <h2>Billing Details</h2>

      <h3 style="margin-top:20px; margin-bottom:12px;">Delivery Address</h3>

      <% if (address.length === 0) { %>
        <p style="color:#888; font-size:14px;">No address found. Please add one.</p>
        <button onclick="openAddressModal()" class="add-address-btn">+ Add Address</button>
      <% } else { %>

        <div class="address-list">
          <% address.forEach((addr, index) => { %>
            <div class="address-card">

              <input
                type="radio"
                name="selectedAddress"
                value="<%= addr._id %>"
                <%= addr.isPrimary || index === 0 ? "checked" : "" %>
              >

              <div class="address-text">
                <strong><%= addr.fullname %></strong><br>
                <%= addr.house %>, <%= addr.place %><br>
                <%= addr.state %> - <%= addr.pincode %><br>
                Phone: <%= addr.phone %>
              </div>

              <button
                type="button"
                class="edit-btn"
                onclick="openEditAddressModal('<%= addr._id %>')"
              >
                Edit
              </button>

            </div>
          <% }) %>
        </div>

      <% } %>

      <button type="button" class="add-address-btn-min" onclick="openAddressModal()">
        + Add Address
      </button>

      <!-- ── Payment ── -->
      <h2 style="margin-top:30px; margin-bottom:14px;">Payment Method</h2>

      <label class="payment-option">
        <input type="radio" name="payment" value="COD" checked>
        <div class="payment-content">
          <strong>Cash on Delivery</strong>
          <p style="color:red;">Available only for orders below ₹1000</p>
        </div>
      </label>

      <label class="payment-option">
        <input type="radio" name="payment" value="RAZORPAY">
        <div class="payment-content">
          <strong>Online Payment (UPI / Card)</strong>
          <p>Secure payment via Razorpay</p>
        </div>
      </label>

      <label class="payment-option">
        <input type="radio" name="payment" value="WALLET">
        <div class="payment-content">
          <strong>Wallet</strong>
          <p>Pay using your wallet balance</p>
        </div>
      </label>

    </div>

    <!-- ═══════════════════════════════════ -->
    <!--  ORDER SUMMARY                     -->
    <!-- ═══════════════════════════════════ -->
    <div class="order-summary">
      <h3 style="margin-bottom:12px;">Your Order</h3>

      <% cartItems.forEach(item => { %>
        <div class="order-item">

          <img
            src="/uploads/product-images/<%= item.productId.images?.[0] %>"
            class="item-img"
            alt="<%= item.productId.product_name %>"
          >

          <div class="item-details">

            <div class="item-title"><%= item.productId.product_name %></div>

            <%
              const original = Math.round(item.productId.sale_price || 0);
              const price    = Math.round(item.productId.discountedPrice || original);
              const offer    = item.productId.appliedOffer || 0;
              const qty      = item.quantity || 0;
              const total    = price * qty;
            %>

            <div class="price-block">
              <div class="price-row">
                <% if (original > price) { %>
                  <div class="old-price">₹<%= original %></div>
                <% } %>
                <% if (offer > 0) { %>
                  <span class="offer"><%= offer %>% OFF</span>
                <% } %>
                <span class="price">₹<%= price %></span>
              </div>
              <div class="meta">Qty <%= qty %> • Total ₹<%= total %></div>
            </div>

          </div>

        </div>
      <% }) %>

      <!-- ── Coupon Section ── -->
      <div class="coupon-container">
        <h4 style="margin-bottom:10px;">Available Coupons</h4>

        <% if (coupons && coupons.length > 0) { %>
          <div class="coupon-list">
            <% coupons.forEach(coupon => { %>
              <div class="coupon-card">
                <div>
                  <div class="coupon-code"><%= coupon.code %></div>
                  <div class="coupon-desc">
                    <%= coupon.discountValue %>
                    <%= coupon.discountType === "percentage" ? "% OFF" : "₹ OFF" %>
                    • Min ₹<%= coupon.minPurchase %>
                    <% if (coupon.maxDiscount && coupon.discountType === "percentage") { %>
                      • Max ₹<%= coupon.maxDiscount %>
                    <% } %>
                  </div>
                </div>
                <button
                  class="coupon-apply-btn"
                  onclick="applyCouponCode('<%= coupon.code %>')"
                >
                  Apply
                </button>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p style="font-size:13px; color:#777;">No coupons available</p>
        <% } %>
      </div>

      <!-- Coupon Input -->
      <div class="coupon-input-row">
        <input
          type="text"
          id="couponInput"
          placeholder="Enter coupon code"
        >
        <button id="applyCouponBtn" onclick="applyCoupon()">Apply</button>
        <button id="removeCouponBtn" style="display:none;" onclick="removeCoupon()">Remove</button>
      </div>

      <!-- Price Summary -->
      <div class="price-summary">

        <% if (offerDiscountTotal > 0) { %>
          <div class="summary-row">
            <span>Offer Discount</span>
            <span style="color:green;">- ₹ <%= offerDiscountTotal %></span>
          </div>
        <% } %>

        <div class="summary-row">
          <span>Subtotal</span>
          <span id="subtotal">₹ <%= cartTotal %></span>
        </div>

        <div class="summary-row" id="couponDiscRow" style="display:none;">
          <span>Coupon Discount</span>
          <span id="couponDiscAmount" style="color:#ff4757;"></span>
        </div>

        <div class="summary-row">
          <span>Shipping</span>
          <span style="color:#16a34a;">Free</span>
        </div>

        <div class="summary-row total">
          <span>Total</span>
          <span id="grandTotal">₹ <%= cartTotal %></span>
        </div>

      </div>

      <button onclick="placeOrder()" class="place-order-btn">
        Place Order
      </button>

    </div>

  </div>
</div>

<%- include("../../views/partials/user/footer") %>

<!-- ═══════════════════════════════════════════ -->
<!--  ADD / EDIT ADDRESS MODAL                  -->
<!-- ═══════════════════════════════════════════ -->
<input type="hidden" id="editAddressId">

<div id="addressModal" class="modal-overlay">
  <div class="modal-box">
    <h2 id="modalTitle">Add New Address</h2>

    <form id="addAddressForm">
      <label>Full Name</label>
      <input name="fullname" class="info-input" placeholder="Full name">
      <small class="error" id="nameError"></small>

      <label>Phone</label>
      <input name="phone" class="info-input" placeholder="10-digit phone number">
      <small class="error" id="phoneError"></small>

      <label>House / Flat No.</label>
      <input name="house" class="info-input" placeholder="House / flat / building">
      <small class="error" id="houseError"></small>

      <label>Place / Area</label>
      <input name="place" class="info-input" placeholder="Street / area / locality">
      <small class="error" id="placeError"></small>

      <label>State</label>
      <input name="state" class="info-input" placeholder="State">
      <small class="error" id="stateError"></small>

      <label>Pincode</label>
      <input name="pincode" class="info-input" placeholder="6-digit pincode">
      <small class="error" id="pincodeError"></small>

      <div class="form-actions">
        <button type="button" class="btn-cancel" onclick="closeAddressModal()">Cancel</button>
        <button type="submit" class="edit-profile-btn">Save Address</button>
      </div>
    </form>
  </div>
</div>

<script>
  // ─────────────────────────────────────────
  //  Coupon state
  // ─────────────────────────────────────────
  let appliedCoupon   = null;   // coupon code string
  let discountAmount  = 0;      // computed discount
  let baseCartTotal   = <%= cartTotal %>;
  let finalAmount     = baseCartTotal;

  // ─────────────────────────────────────────
  //  Apply coupon (from input field)
  // ─────────────────────────────────────────
  async function applyCoupon() {
    if (appliedCoupon) {
      Swal.fire({ icon: "info", title: "Coupon Already Applied", text: "Remove the current coupon first." });
      return;
    }

    const code = document.getElementById("couponInput").value.trim().toUpperCase();
    if (!code) {
      Swal.fire({ icon: "warning", title: "Enter Coupon Code" });
      return;
    }

    try {
      const res  = await fetch("/coupon/apply", {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({ code, cartTotal: baseCartTotal })
      });

      const data = await res.json();

      if (!data.success) {
        Swal.fire({ icon: "error", title: "Coupon Error", text: data.message });
        return;
      }

      // ── Update state ──
      appliedCoupon  = data.couponCode;
      discountAmount = data.discount;
      finalAmount    = data.grandTotal;

      // ── Update UI ──
      document.getElementById("couponDiscRow").style.display    = "flex";
      document.getElementById("couponDiscAmount").innerText     = `- ₹ ${discountAmount}`;
      document.getElementById("grandTotal").innerText           = `₹ ${finalAmount}`;
      document.getElementById("applyCouponBtn").style.display   = "none";
      document.getElementById("removeCouponBtn").style.display  = "inline-block";
      document.getElementById("couponInput").value              = appliedCoupon;

      Swal.fire({ icon: "success", title: "Coupon Applied!", text: `You saved ₹${discountAmount}`, timer: 1800, showConfirmButton: false });

    } catch (err) {
      console.error(err);
      Swal.fire({ icon: "error", title: "Server Error" });
    }
  }

  // ─────────────────────────────────────────
  //  Apply coupon from the coupon card button
  // ─────────────────────────────────────────
  function applyCouponCode(code) {
    if (appliedCoupon) {
      Swal.fire({ icon: "info", title: "Remove current coupon first" });
      return;
    }
    document.getElementById("couponInput").value = code;
    applyCoupon();
  }

  // ─────────────────────────────────────────
  //  Remove coupon
  // ─────────────────────────────────────────
  function removeCoupon() {
    appliedCoupon  = null;
    discountAmount = 0;
    finalAmount    = baseCartTotal;

    document.getElementById("couponDiscRow").style.display    = "none";
    document.getElementById("couponDiscAmount").innerText     = "";
    document.getElementById("grandTotal").innerText           = `₹ ${baseCartTotal}`;
    document.getElementById("applyCouponBtn").style.display   = "inline-block";
    document.getElementById("removeCouponBtn").style.display  = "none";
    document.getElementById("couponInput").value              = "";

    Swal.fire({ icon: "success", title: "Coupon Removed", timer: 1200, showConfirmButton: false });
  }

  // ─────────────────────────────────────────
  //  Place Order
  // ─────────────────────────────────────────
  async function placeOrder() {
    const selectedAddressEl = document.querySelector('input[name="selectedAddress"]:checked');
    if (!selectedAddressEl) {
      Swal.fire({ icon: "warning", title: "Select Address", text: "Please select a delivery address." });
      return;
    }

    const paymentMethod = document.querySelector('input[name="payment"]:checked').value;

    if (paymentMethod === "COD" && finalAmount > 1000) {
      Swal.fire({
        icon:  "warning",
        title: "COD Not Available",
        text:  "Cash on Delivery is only available for orders below ₹1000. Please choose another payment method.",
        confirmButtonColor: "#ff4757"
      });
      return;
    }

    // 1️⃣ Create order on backend
    let orderData;
    try {
      const orderRes = await fetch("/order/place", {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({
          addressId:     selectedAddressEl.value,
          paymentMethod,
          couponCode:    appliedCoupon,    // backend will re-validate
          discountAmount,
          finalAmount
        })
      });

      orderData = await orderRes.json();

      if (!orderRes.ok || !orderData.success) {
        Swal.fire({ icon: "error", title: "Order Failed", text: orderData.message || "Something went wrong." });
        return;
      }
    } catch (err) {
      Swal.fire({ icon: "error", title: "Server Error" });
      return;
    }

    // 2️⃣ COD or Wallet → go to success page
    if (paymentMethod === "COD" || paymentMethod === "WALLET") {
      window.location.href = `/order-success/${orderData.orderId}`;
      return;
    }

    // 3️⃣ Razorpay → create Razorpay order
    let razorData;
    try {
      const razorRes = await fetch("/create-order", {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({ orderId: orderData.orderId })
      });

      razorData = await razorRes.json();

      if (!razorData.success) {
        Swal.fire({ icon: "error", title: "Payment Initialization Failed" });
        return;
      }
    } catch (err) {
      Swal.fire({ icon: "error", title: "Server Error" });
      return;
    }

    const options = {
      key:       razorData.key,
      amount:    razorData.razorpayOrder.amount,
      currency:  "INR",
      order_id:  razorData.razorpayOrder.id,
      name:      "Bookshelves",
      modal: {
        ondismiss: function () {
          window.location.href = `/order-failed/${orderData.orderId}`;
        }
      },
      handler: async function (response) {
        try {
          const verifyRes = await fetch("/verify", {
            method:  "POST",
            headers: { "Content-Type": "application/json" },
            body:    JSON.stringify({ ...response, orderId: orderData.orderId })
          });

          const verifyData = await verifyRes.json();

          if (verifyData.success) {
            window.location.href = `/order-success/${orderData.orderId}`;
          } else {
            window.location.href = `/order-failed/${orderData.orderId}`;
          }
        } catch (err) {
          window.location.href = `/order-failed/${orderData.orderId}`;
        }
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();
  }

  // ─────────────────────────────────────────
  //  Address Modal
  // ─────────────────────────────────────────
  function openAddressModal() {
    document.getElementById("editAddressId").value = "";
    document.getElementById("modalTitle").innerText = "Add New Address";
    document.getElementById("addAddressForm").reset();
    document.getElementById("addressModal").style.display = "flex";
  }

  async function openEditAddressModal(addressId) {
    try {
      const res    = await fetch(`/address/${addressId}`);
      const result = await res.json();

      if (!result.success) {
        Swal.fire({ icon: "error", title: "Unable to load address" });
        return;
      }

      const addr = result.address;
      const form = document.getElementById("addAddressForm");

      document.getElementById("editAddressId").value  = addressId;
      document.getElementById("modalTitle").innerText = "Edit Address";

      form.fullname.value = addr.fullname;
      form.phone.value    = addr.phone;
      form.house.value    = addr.house;
      form.place.value    = addr.place;
      form.state.value    = addr.state;
      form.pincode.value  = addr.pincode;

      document.getElementById("addressModal").style.display = "flex";
    } catch (err) {
      Swal.fire({ icon: "error", title: "Server Error" });
    }
  }

  function closeAddressModal() {
    document.getElementById("addressModal").style.display = "none";
    document.getElementById("addAddressForm").reset();
    document.getElementById("editAddressId").value = "";
  }

  document.getElementById("addAddressForm").addEventListener("submit", async (e) => {
    e.preventDefault();

    const form      = e.target;
    const addressId = document.getElementById("editAddressId").value;

    const data = {
      fullname: form.fullname.value.trim(),
      phone:    form.phone.value.trim(),
      house:    form.house.value.trim(),
      place:    form.place.value.trim(),
      state:    form.state.value.trim(),
      pincode:  form.pincode.value.trim()
    };

    const url    = addressId ? `/address/edit/${addressId}` : "/address/add";
    const method = addressId ? "PATCH" : "POST";

    try {
      const res    = await fetch(url, {
        method,
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(data)
      });
      const result = await res.json();

      if (result.success) {
        Swal.fire({
          icon:               "success",
          title:              addressId ? "Address Updated" : "Address Added",
          timer:              1500,
          showConfirmButton:  false
        });
        closeAddressModal();
        setTimeout(() => location.reload(), 800);
      } else {
        Swal.fire({ icon: "error", title: "Error", text: result.message });
      }
    } catch (err) {
      Swal.fire({ icon: "error", title: "Server Error" });
    }
  });

  // Close modal on backdrop click or Escape
  document.getElementById("addressModal").addEventListener("click", (e) => {
    if (e.target.id === "addressModal") closeAddressModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAddressModal();
  });
</script>

</body>
</html>
