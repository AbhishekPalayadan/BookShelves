<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <title>Wishlist - Bookshelves</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f5f5f5;
            color: #333;
        }

        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(-20px);
            background: #1f2937;
            color: #fff;
            padding: 12px 20px;
            border-radius: 8px;
            font-size: 14px;
            opacity: 0;
            transition: all 0.3s ease;
            z-index: 9999;
            white-space: nowrap;
        }

        .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
        .toast.toast-error   { background: #dc2626; }
        .toast.toast-warning { background: #d97706; }
        .toast.toast-success { background: #16a34a; }

        .wishlist-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e0e0e0;
        }

        .wishlist-header h1 { font-size: 24px; font-weight: 600; }

        .move-all-btn {
            background-color: #fff;
            border: 2px solid #333;
            padding: 10px 24px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .move-all-btn:hover { background-color: #333; color: #fff; }

        .wishlist-items { display: flex; flex-direction: column; gap: 20px; }

        .wishlist-item {
            display: flex;
            gap: 30px;
            padding: 20px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            background-color: #fafafa;
            width: 100%;
        }

        .wishlist-item.unavailable {
            opacity: 0.78;
            border-color: #fca5a5;
            background-color: #fff5f5;
        }

        .item-image {
            flex-shrink: 0;
            width: 120px;
            height: 180px;
            overflow: hidden;
            border-radius: 4px;
        }

        .item-image img { width: 100%; height: 100%; object-fit: cover; }

        .item-details { flex: 1; }

        .item-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #333;
        }

        .item-rating {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }

        .stars { color: #ffc107; font-size: 14px; }
        .review-count { color: #999; font-size: 13px; }

        .item-pricing {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 12px;
        }

        .price { font-size: 18px; font-weight: 600; color: #333; }

        /* Availability badges */
        .availability-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .badge-out-of-stock {
            background-color: #fef3c7;
            color: #92400e;
            border: 1px solid #fcd34d;
        }

        .badge-unavailable {
            background-color: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .item-actions { display: flex; gap: 10px; }

        .remove-btn {
            background-color: #ff4d4d;
            color: white;
            border: none;
            padding: 10px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: 0.3s;
        }

        .remove-btn:hover { background-color: #ff0000; }

        .add-to-cart-btn {
            flex: 1;
            background: #4caf50;
            color: #fff;
            border: 1px solid #43a047;
            padding: 12px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s ease;
        }

        .add-to-cart-btn:hover { background: #43a047; border-color: #388e3c; transform: translateY(-1px); }
        .add-to-cart-btn:active { transform: scale(0.97); }

        .add-to-cart-btn:disabled {
            background: #d1d5db;
            border-color: #d1d5db;
            color: #6b7280;
            cursor: not-allowed;
            transform: none;
        }

        .main-container { max-width: 1200px; margin: 26px auto; padding: 0 20px; }

        .breadcrumb {
            display: flex;
            justify-content: space-between;
            margin-bottom: 28px;
            font-size: 14px;
            color: #6b7280;
        }

        .breadcrumb a { color: #6b7280; text-decoration: none; }
        .breadcrumb a:hover { color: #ff4757; }
        .customer-name { color: #ff4757; font-weight: 600; }

        .profile-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 30px;
            align-items: flex-start;
        }

        .content-card {
            background: #fff;
            border-radius: 14px;
            padding: 30px;
            box-shadow: 0 8px 28px rgba(0,0,0,.08);
        }

        .empty-wishlist {
            text-align: center;
            padding: 60px 20px;
            color: #6b7280;
            font-size: 16px;
        }

        .empty-wishlist i {
            font-size: 48px;
            color: #fca5a5;
            margin-bottom: 16px;
            display: block;
        }

        @media (max-width: 768px) {
            .wishlist-item {
                flex-direction: column;
                align-items: center;
                text-align: center;
                gap: 20px;
            }

            .item-actions { width: 100%; }
            .remove-btn, .add-to-cart-btn { flex: 1; }

            .wishlist-header { flex-direction: column; gap: 15px; text-align: center; }

            .profile-layout { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<%- include("../../views/partials/user/header") %>
<div id="toast" class="toast"></div>

<div class="main-container">

    <div class="breadcrumb">
        <div><a href="/">Home</a> / My Wishlist</div>
        <div>Welcome, <span class="customer-name"><%= user.fullname %></span></div>
    </div>

    <div class="profile-layout">

        <%- include("../partials/user/profileSidebar",{ user, activeMenu:"wishlist" }) %>

        <div class="content-card">

            <div class="wishlist-header">
                <h1>Wishlist (<%= wishlist.filter(p => p && !p.isDeleted).length %> items)</h1>
                <button class="move-all-btn" onclick="moveAllToCart()">
                    Move All To Bag
                </button>
            </div>

            <div class="wishlist-items">

                <% if (!wishlist || wishlist.filter(p => p && !p.isDeleted).length === 0) { %>
                    <div class="empty-wishlist">
                        <i class="fa-regular fa-heart"></i>
                        <p>Your wishlist is empty</p>
                    </div>
                <% } %>

                <% wishlist.forEach(product => { %>
                <% if (product && !product.isDeleted) { %>

                <%
                    const isOutOfStock  = product.status === 'out_of_stock' || product.stock < 1;
                    const isRemoved     = product.status === 'removed';
                    const isUnavailable = isOutOfStock || isRemoved;
                %>

                <div class="wishlist-item <%= isUnavailable ? 'unavailable' : '' %>">

                    <div class="item-image">
                        <% if (product.images && product.images.length > 0) { %>
                            <img src="/uploads/product-images/<%= product.images[0] %>" alt="<%= product.product_name %>">
                        <% } else { %>
                            <img src="/images/no-image.png" alt="No image">
                        <% } %>
                    </div>

                    <div class="item-details">

                        <div class="item-title"><%= product.product_name %></div>

                        <div class="item-rating">
                            <span class="stars">★★★★★</span>
                            <span class="review-count">(<%= product.number_of_reviews %>)</span>
                        </div>

                        <div class="item-pricing">
                            <span class="price">₹ <%= product.sale_price %></span>
                        </div>

                        <!-- Availability badge -->
                        <% if (isRemoved) { %>
                            <div class="availability-badge badge-unavailable">
                                <i class="fa-solid fa-ban"></i> Currently Unavailable
                            </div>
                        <% } else if (isOutOfStock) { %>
                            <div class="availability-badge badge-out-of-stock">
                                <i class="fa-solid fa-triangle-exclamation"></i> Out of Stock
                            </div>
                        <% } %>

                        <div class="item-actions">
                            <button class="remove-btn"
                                onclick="removeFromWishlist('<%= product._id %>')">
                                <i class="fa-solid fa-trash"></i> Remove
                            </button>

                            <button class="add-to-cart-btn"
                                onclick="addToCart('<%= product._id %>')"
                                <% if (isUnavailable) { %>
                                    disabled
                                    title="<%= isRemoved ? 'This product is currently unavailable' : 'This product is out of stock' %>"
                                <% } %>>
                                <i class="fa-solid fa-cart-shopping"></i>
                                <%= isUnavailable ? 'Unavailable' : 'Add to Cart' %>
                            </button>
                        </div>

                    </div>
                </div>

                <% } %>
                <% }) %>

            </div>
        </div>
    </div>
</div>

<%- include("../../views/partials/user/footer") %>

<script>
    async function removeFromWishlist(productId) {
        try {
            await fetch(`/wishlist/remove/${productId}`, { method: "DELETE" });
            showToast("❌ Item removed from wishlist", "toast-error");
            setTimeout(() => location.reload(), 1500);
        } catch (err) {
            showToast("⚠️ Network error. Please try again.", "toast-warning");
        }
    }

    async function addToCart(productId) {
        try {
            const res  = await fetch("/cart/add", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ productId, quantity: 1 })
            });

            const data = await res.json();

            if (!res.ok || data.success === false) {
                // Show exact error from server — do NOT remove from wishlist
                showToast("⚠️ " + (data.message || "Could not add to cart"), "toast-warning");
                return;
            }

            showToast("🛒 Item added to cart!", "toast-success");

            // Only remove from wishlist after confirmed cart add
            await fetch(`/wishlist/remove/${productId}`, { method: "DELETE" });
            setTimeout(() => location.reload(), 2000);

        } catch (err) {
            showToast("⚠️ Network error. Please try again.", "toast-warning");
        }
    }

    async function moveAllToCart() {
        try {
            const res  = await fetch("/wishlist/move-all", { method: "POST" });
            const data = await res.json();

            if (!res.ok || data.success === false) {
                showToast("⚠️ Something went wrong. Please try again.", "toast-warning");
                return;
            }

            if (data.moved === 0 && data.skipped > 0) {
                showToast(`⚠️ No items moved — Item(s) are unavailable or out of stock`, "toast-warning");
            } else if (data.skipped > 0) {
                showToast(`📦 ${data.moved} item(s) moved. ${data.skipped} skipped (unavailable/out of stock)`, "toast-warning");
            } else {
                showToast("📦 All items moved to cart!", "toast-success");
            }

            setTimeout(() => location.reload(), 2500);

        } catch (err) {
            showToast("⚠️ Network error. Please try again.", "toast-warning");
        }
    }

    function showToast(message, type = "") {
        const toast = document.getElementById("toast");
        toast.textContent = message;
        // Reset classes then apply new ones
        toast.className = "toast " + type;
        toast.classList.add("show");
        setTimeout(() => toast.classList.remove("show"), 3000);
    }
</script>

</body>
</html>