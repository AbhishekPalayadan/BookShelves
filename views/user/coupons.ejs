<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Coupons | Bookshelves</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body { font-family:'Inter','Segoe UI',sans-serif; background:#f5f6f8; }
    .main-container{max-width:1200px;margin:26px auto;padding:0 20px}
    .breadcrumb{display:flex;justify-content:space-between;margin-bottom:28px;font-size:14px;color:#6b7280}
    .profile-layout{display:grid;grid-template-columns:280px 1fr;gap:30px}
    .content-card{background:#fff;border-radius:14px;padding:30px;box-shadow:0 8px 28px rgba(0,0,0,.08)}
    .coupon-card{
      border:1px solid #eee;
      padding:18px;
      border-radius:10px;
      margin-bottom:15px;
      background:#fff5f5;
    }
    .coupon-code{
      font-size:18px;
      font-weight:700;
      color:#ff4757;
    }
    .expiry{
      font-size:13px;
      color:#888;
      margin-top:6px;
    }
  </style>
</head>

<body>

<%- include("../../views/partials/user/header") %>

<div class="main-container">

  <div class="breadcrumb">
    <div><a href="/">Home</a> / My Coupons</div>
    <div>Welcome, <strong><%= user.fullname %></strong></div>
  </div>

  <div class="profile-layout">

    <%- include("../partials/user/profileSidebar",{ user, activeMenu:"coupons" }) %>

    <div class="content-card">
      <h2>Available Coupons</h2>

      <% if(coupons.length === 0){ %>
        <p style="margin-top:20px;">No active coupons available.</p>
      <% } else { %>

        <% coupons.forEach(coupon => { %>
          <div class="coupon-card">
            <div class="coupon-code">
              <%= coupon.code %>
            </div>

            <div>
              <strong><%= coupon.discountValue %>% OFF</strong>
              <% if(coupon.maxDiscount){ %>
                (Max ₹ <%= coupon.maxDiscount %>)
              <% } %>
            </div>

            <div>
              Minimum Purchase: ₹ <%= coupon.minPurchase %>
            </div>

            <div class="expiry">
              Valid till: <%= new Date(coupon.expiryDate).toLocaleDateString() %>
            </div>
          </div>
        <% }) %>

      <% } %>

    </div>
  </div>
</div>

<%- include("../../views/partials/user/footer") %>

</body>
</html>