<%- include("../partials/user/header") %>

<main class="main-content">
    <div class="breadcrumb">
        <a href="/login">Login</a> /
        <span>Forgot Password</span>
    </div>

    <div class="container"
        style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px; background-color: #fff; margin-bottom: 65px;">

        <form id="form" class="forgot-password-form" method="POST" action="/forgot-password"
            style="max-width: 500px; width: 100%; text-align: center;">

            <h1 style="font-size: 32px; font-weight: 600; margin-bottom: 15px; color: #000;">Forgot Password?</h1>
            <p style="color: #666; font-size: 14px; margin-bottom: 40px;">Enter your registered email</p>

            <p id="emailError" style="color: red; font-weight: bold; margin-bottom: 20px; margin-top: -15px; display: <%= message ? 'block' : 'none' %>;">
                <%= message || '' %>
            </p>

            <div class="form-group" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px;">
                <input 
                    id="email" 
                    name="email" 
                    type="email"
                    placeholder="Enter your email"
                    style="padding: 12px 16px; border: none; border-bottom: 1px solid #ddd; font-size: 14px; outline: none; background-color: #f9f9f9;">
            </div>

            <div class="form-actions"
                style="display: flex; justify-content: space-between; align-items: center; margin-top: 30px;">
                <a href="/login" class="go-back" style="color: #ff1744; text-decoration: none; font-size: 14px;">
                    Back to Login
                </a>
                <button type="submit" class="verify-btn"
                    style="background-color: #000; color: #fff; border: none; padding: 12px 40px; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 600;">
                    Verify Email
                </button>
            </div>

        </form>
    </div>
</main>

<script>
    const form = document.getElementById('form');
    const emailError = document.getElementById('emailError');
    const emailInput = document.getElementById('email');
    const submitBtn = document.querySelector('.verify-btn');

    function showError(message) {
        emailError.innerText = message;
        emailError.style.display = 'block';
        emailInput.style.borderBottom = '1px solid red';
    }

    function clearError() {
        emailError.innerText = '';
        emailError.style.display = 'none';
        emailInput.style.borderBottom = '1px solid #ddd';
    }

    function validateEmail(value) {
        const pattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return pattern.test(value);
    }

    emailInput.addEventListener('input', function () {
        const value = emailInput.value.trim();

        if (value === '') {
            showError('Email is required');
            submitBtn.disabled = true;
            return;
        }

        if (!validateEmail(value)) {
            showError('Enter a valid email address');
            submitBtn.disabled = true;
            return;
        }

        clearError();
        submitBtn.disabled = false;
    });

    form.addEventListener('submit', function (e) {
        const value = emailInput.value.trim();

        if (value === '') {
            e.preventDefault();
            showError('Email is required');
            return;
        }

        if (!validateEmail(value)) {
            e.preventDefault();
            showError('Enter a valid email address');
            return;
        }
    });
</script>

<%- include("../partials/user/footer") %>