<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmed</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f6f9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .card {
            width: 100%;
            max-width: 540px;
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #e8ecf0;
            overflow: hidden;
        }

        /* ── Header band ── */
        .card-header {
            background: #1a4fd8;
            padding: 36px 40px 30px;
            text-align: center;
            position: relative;
        }

        .icon-ring {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(255,255,255,0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            border: 2px solid rgba(255,255,255,0.35);
        }

        .icon-ring svg {
            width: 34px;
            height: 34px;
            stroke: #ffffff;
            stroke-width: 2.5;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .card-header h1 {
            font-size: 22px;
            font-weight: 600;
            color: #ffffff;
            letter-spacing: -0.3px;
        }

        .card-header p {
            font-size: 13px;
            color: rgba(255,255,255,0.75);
            margin-top: 6px;
        }

        /* ── Body ── */
        .card-body { padding: 28px 32px; }

        /* ── Amount highlight ── */
        .amount-badge {
            background: #f0f5ff;
            border: 1px solid #c7d9ff;
            border-radius: 8px;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .amount-label {
            font-size: 13px;
            color: #5a6a85;
            font-weight: 500;
        }

        .amount-value {
            font-size: 22px;
            font-weight: 700;
            color: #1a4fd8;
            letter-spacing: -0.5px;
        }

        /* ── Details list ── */
        .details-list {
            border: 1px solid #e8ecf0;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 13px 18px;
            font-size: 13px;
            border-bottom: 1px solid #f0f2f5;
            gap: 12px;
        }

        .detail-row:last-child { border-bottom: none; }

        .detail-label {
            color: #6b7a95;
            font-weight: 500;
            white-space: nowrap;
        }

        .detail-value {
            color: #1e2740;
            font-weight: 600;
            text-align: right;
        }

        /* ── Delivery strip ── */
        .delivery-strip {
            background: #f0faf4;
            border: 1px solid #b7e8c9;
            border-radius: 8px;
            padding: 13px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
            font-size: 13px;
        }

        .delivery-strip i {
            color: #1a9e50;
            font-size: 15px;
            flex-shrink: 0;
        }

        .delivery-strip span { color: #145c31; font-weight: 500; }
        .delivery-strip strong { color: #0f4424; }

        /* ── Buttons ── */
        .btn-group {
            display: flex;
            gap: 12px;
        }

        .btn {
            flex: 1;
            padding: 13px 16px;
            font-size: 13px;
            font-weight: 600;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            transition: filter 0.15s ease, transform 0.1s ease;
        }

        .btn:active { transform: scale(0.98); }
        .btn:hover { filter: brightness(0.93); }

        .btn-primary {
            background: #1a4fd8;
            color: #ffffff;
        }

        .btn-secondary {
            background: #f0f2f5;
            color: #3a4a65;
        }

        @media (max-width: 480px) {
            .card-body { padding: 22px 18px; }
            .card-header { padding: 28px 20px 24px; }
            .btn-group { flex-direction: column; }
        }
    </style>
</head>
<body>

<div class="card">

    <div class="card-header">
        <div class="icon-ring">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h1>Payment Successful</h1>
        <p>Your order has been confirmed and is being processed.</p>
    </div>

    <div class="card-body">

        <%
            const offerDisc  = order.pricing?.offerDiscount  || 0;
            const couponDisc = order.pricing?.couponDiscount  || 0;
            const subtotal   = order.pricing?.subtotal        || order.totalAmount || 0;
            const finalAmt   = order.pricing?.finalAmount     ?? order.totalAmount ?? 0;
        %>

        <div class="amount-badge">
            <span class="amount-label">Amount Paid</span>
            <span class="amount-value">₹<%= Number(finalAmt).toFixed(2) %></span>
        </div>

        <div class="details-list">
            <div class="detail-row">
                <span class="detail-label">Order ID</span>
                <span class="detail-value">#<%= order.orderId %></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Date</span>
                <span class="detail-value">
                    <%= new Date(order.createdAt).toLocaleDateString("en-IN", { day:"numeric", month:"short", year:"numeric" }) %>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Time</span>
                <span class="detail-value">
                    <%= new Date(order.createdAt).toLocaleTimeString("en-IN", { hour:"2-digit", minute:"2-digit", hour12:true }) %>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Payment Method</span>
                <span class="detail-value">
                    <%= order.paymentMethod === "COD" ? "Cash on Delivery" : order.paymentMethod === "RAZORPAY" ? "UPI / Razorpay" : order.paymentMethod %>
                </span>
            </div>
            <% if (offerDisc > 0) { %>
            <div class="detail-row">
                <span class="detail-label">Offer Discount</span>
                <span class="detail-value" style="color:#1a9e50;">−₹<%= Number(offerDisc).toFixed(2) %></span>
            </div>
            <% } %>
            <% if (couponDisc > 0) { %>
            <div class="detail-row">
                <span class="detail-label">Coupon Discount</span>
                <span class="detail-value" style="color:#1a9e50;">−₹<%= Number(couponDisc).toFixed(2) %></span>
            </div>
            <% } %>
        </div>

        <div class="delivery-strip">
            <i class="fas fa-truck-fast"></i>
            <span>Estimated delivery by &nbsp;<strong>
                <%= expectedDelivery.toLocaleDateString("en-IN", { day:"numeric", month:"long", year:"numeric" }) %>
            </strong></span>
        </div>

        <div class="btn-group">
            <a href="/orders/<%= order.orderId %>" class="btn btn-secondary">
                <i class="fas fa-box"></i> View Order
            </a>
            <a href="/products" class="btn btn-primary">
                <i class="fas fa-arrow-right"></i> Continue Shopping
            </a>
        </div>

    </div>
</div>

</body>
</html>
